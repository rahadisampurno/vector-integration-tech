---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="Cyber Security & Zero Trust | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Infrastruktur
            <details class="group p-6 rounded-2xl bg-surface-container-low border border-outline-variant/15 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-all hover:bg-surface-container">
                <summary class="flex items-center justify-between font-bold text-slate-900 dark:text-white">
                    Seberapa sering audit keamanan harus dilakukan?
                    <span class="material-symbols-outlined transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <p class="mt-4 text-sm text-on-surface-variant leading-relaxed font-body">
                    Idealnya, audit menyeluruh dilakukan setiap 6 bulan sekali atau setiap kali ada perubahan signifikan pada infrastruktur IT Anda. Namun, pemantauan otomatis (automated scanning) sebaiknya berjalan secara berkelanjutan 24/7.
                </p>
            </details>
            <details class="group p-6 rounded-2xl bg-surface-container-low border border-outline-variant/15 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-all hover:bg-surface-container">
                <summary class="flex items-center justify-between font-bold text-slate-900 dark:text-white">
                    Apa yang harus dilakukan jika bisnis kami baru saja terkena serangan siber?
                    <span class="material-symbols-outlined transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <p class="mt-4 text-sm text-on-surface-variant leading-relaxed font-body">
                    Hubungi tim kami segera. Kami menyediakan layanan tanggap insiden (Incident Response) untuk mengisolasi ancaman, melakukan forensik digital, dan memulihkan sistem Anda secepat mungkin guna meminimalkan kerugian data dan operasional.
                </p>
            </details>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Cyber Security <br/><span class="text-primary-fixed-dim">& Zero Trust.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Melindungi infrastruktur digital Anda dengan arsitektur Zero Trust, audit keamanan berkala, dan sistem pertahanan berlapis terhadap ancaman siber.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="Cyber Security" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Layanan Keamanan</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">verified_user</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Arsitektur Zero Trust</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Implementasi prinsip "never trust, always verify" untuk setiap akses ke sumber daya jaringan Anda.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">policy</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Audit Keamanan Berkala</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Pengujian penetrasi dan pemindaian kerentanan untuk memastikan sistem Anda selalu aman dari ancaman terbaru.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">lock</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Enkripsi Data</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Perlindungan data sensitif perusahaan baik saat disimpan (at rest) maupun saat dikirim (in transit).</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Pertahanan Berlapis untuk Aset Digital</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Ancaman siber terus berkembang. Pendekatan keamanan tradisional tidak lagi cukup. Kami membantu Anda membangun benteng digital yang adaptif dan tangguh.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">security_update_good</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Kepatuhan Standar Global</h4>
                                <p class="text-sm text-on-surface-variant">Pastikan sistem Anda memenuhi standar regulasi seperti GDPR, ISO 27001, dan regulasi lokal.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">visibility</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Visibilitas Penuh</h4>
                                <p class="text-sm text-on-surface-variant">Pantau setiap anomali dalam jaringan Anda dengan dashboard monitoring keamanan real-time.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">gpp_maybe</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Mitigasi Risiko Proaktif</h4>
                                <p class="text-sm text-on-surface-variant">Temukan dan tambal celah keamanan sebelum penyerang sempat memanfaatkannya.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Methodology -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Metodologi Keamanan</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Identifikasi & Penilaian</h4>
                            <p class="text-sm text-on-surface-variant">Inventarisasi aset digital dan penilaian risiko terhadap potensi ancaman.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Proteksi & Deteksi</h4>
                            <p class="text-sm text-on-surface-variant">Implementasi kontrol keamanan dan sistem deteksi intrusi (IDS/IPS).</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Respon & Pemulihan</h4>
                            <p class="text-sm text-on-surface-variant">Penyusunan rencana tanggap insiden dan strategi backup/disaster recovery.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Amankan Aset Berharga Anda Sekarang."
        description="Jangan tunggu hingga terjadi insiden. Bangun pertahanan siber yang tangguh bersama tim ahli kami."
        ctaText="Konsultasi Keamanan Gratis"
        
    />

    <ServiceBottomSections currentSlug="cyber-security" />

</main>
</BaseLayout>
