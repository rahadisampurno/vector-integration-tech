---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="Integrasi Sistem API | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Infrastruktur
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Integrasi <br/><span class="text-primary-fixed-dim">Sistem API.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Menghubungkan aplikasi pihak ketiga, database, dan sistem internal Anda melalui pipeline API yang aman dan terorkestrasi secara sempurna.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="API Integration" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Layanan Integrasi</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">api</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">API Development</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Membangun API RESTful atau GraphQL yang aman, terdokumentasi, dan berperforma tinggi.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">sync</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Sinkronisasi Data</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Memastikan data di berbagai platform (CRM, ERP, Database) selalu sinkron secara real-time.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">cloud_done</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Migrasi Cloud</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Memindahkan sistem on-premise Anda ke infrastruktur cloud modern dengan downtime minimal.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Satukan Ekosistem Digital Anda</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Data yang terfragmentasi adalah penghambat inovasi. Layanan integrasi kami memastikan setiap komponen dalam tumpukan teknologi Anda berkomunikasi secara harmonis.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">database</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Integritas Data Terjamin</h4>
                                <p class="text-sm text-on-surface-variant">Hilangkan silo data dan pastikan informasi yang sama tersedia di seluruh departemen perusahaan Anda.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">bolt</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Otomatisasi Alur Kerja</h4>
                                <p class="text-sm text-on-surface-variant">Hubungkan aplikasi berbeda untuk menjalankan tugas otomatis tanpa intervensi manual.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">lock</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Keamanan API Tingkat Tinggi</h4>
                                <p class="text-sm text-on-surface-variant">Implementasi OAuth2, API Keys, dan enkripsi end-to-end untuk melindungi pertukaran data sensitif.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Workflow -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Proses Integrasi</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Mapping Arsitektur</h4>
                            <p class="text-sm text-on-surface-variant">Kami memetakan seluruh titik data dan sistem yang perlu dihubungkan.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Pengembangan Middleware</h4>
                            <p class="text-sm text-on-surface-variant">Membangun jembatan (middleware) atau pipeline API yang efisien dan scalable.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Testing & Deployment</h4>
                            <p class="text-sm text-on-surface-variant">Uji coba beban dan keamanan sebelum sistem dijalankan secara penuh.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Hubungkan Bisnis Anda dengan Masa Depan."
        description="Hilangkan batasan antar aplikasi. Mulai integrasikan sistem Anda untuk efisiensi maksimal."
        ctaText="Konsultasi Integrasi Gratis"
        
    />

    <ServiceBottomSections currentSlug="integrasi-api" />

</main>
</BaseLayout>
