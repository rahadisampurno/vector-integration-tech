---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../../components/ServiceBottomSections.astro";
---

<BaseLayout title="E-commerce Solutions | Services">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-amber-400/10 border border-amber-400/20 rounded-full text-amber-500 text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
            Services — Business
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    E-commerce <br/><span class="text-amber-500">Solutions.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Build your own custom online store with integrated payment systems, inventory management, and advanced sales analytics dashboards.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/en/contact" class="bg-amber-500 text-white px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Free Consultation <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1557821552-17105176677c?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="E-commerce" />
                <div class="absolute inset-0 bg-gradient-to-br from-amber-400/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Online Store Features</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-amber-400 to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-amber-500 text-4xl mb-5 block">payments</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Payment Gateway</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Automatic integration with various secure payment methods (VA, E-wallet, Credit Card).</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-amber-500 text-4xl mb-5 block">inventory_2</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Inventory Management</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Manage your product stock in real-time with automatic notifications when stock is low.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-amber-500 text-4xl mb-5 block">local_shipping</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Integrated Logistics</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Automatically check shipping rates and track orders directly from your store dashboard.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Online Stores That Work for You</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Don't limit your sales to marketplaces. Have a custom e-commerce platform that gives you full control over your brand and customer data.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-amber-400/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-amber-500">monitoring</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">In-depth Sales Analytics</h4>
                                <p class="text-sm text-on-surface-variant">Understand your buyer behavior with comprehensive report dashboards for better marketing strategies.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-amber-400/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-amber-500">security</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Transaction Security</h4>
                                <p class="text-sm text-on-surface-variant">Customer data protection and transaction encryption to build buyer trust.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-amber-400/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-amber-500">mobile_friendly</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Mobile-First Experience</h4>
                                <p class="text-sm text-on-surface-variant">Since most buyers use smartphones, our online stores are optimized for a seamless mobile experience.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Features List -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Other Key Features</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">confirmation_number</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Coupon & Discount System</span>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">reviews</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Product Review & Rating</span>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">account_circle</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Member Management</span>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">mail</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Automated Email Marketing</span>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">category</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Product Variations (Color/Size)</span>
                    </div>
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-amber-500 text-sm">list_alt</span>
                        <span class="text-xs text-slate-700 dark:text-slate-300">Export Reports to Excel</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem title="Ecosystem & Deep Integration" description="Our solutions are perfectly designed to connect seamlessly with your existing applications and technology infrastructure." />

    <WhyChooseUs title="Why Choose VeinTech?" subtitle="Our approach isn't just about writing code. We deliver end-to-end business solutions that guarantee ROI, security, and long-term scalability." />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Start Selling Professionally."
        description="Ready to scale your sales? Let's build a robust online store for your business."
        ctaText="Free Online Store Consultation"
        ctaLink="/en/contact"
    />

    <ServiceBottomSections currentSlug="ecommerce-solutions" />

</main>
</BaseLayout>
