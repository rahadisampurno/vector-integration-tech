---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../../components/ServiceBottomSections.astro";
---

<BaseLayout title="Cyber Security & Zero Trust | Services">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Services — Infrastructure
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Cyber Security <br/><span class="text-primary-fixed-dim">& Zero Trust.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Protecting your digital infrastructure with Zero Trust architecture, regular security audits, and multi-layered defense systems against cyber threats.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/en/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Free Consultation <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="Cyber Security" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Security Services</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">verified_user</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Zero Trust Architecture</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Implementation of "never trust, always verify" principles for every access to your network resources.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">policy</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Regular Security Audits</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Penetration testing and vulnerability scanning to ensure your system is always safe from the latest threats.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">lock</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Data Encryption</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Protection of sensitive enterprise data both at rest and in transit.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Multi-Layered Defense for Digital Assets</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Cyber threats are constantly evolving. Traditional security approaches are no longer enough. We help you build a digital fortress that is adaptive and resilient.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">security_update_good</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Global Standard Compliance</h4>
                                <p class="text-sm text-on-surface-variant">Ensure your systems meet regulatory standards such as GDPR, ISO 27001, and local regulations.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">visibility</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Full Visibility</h4>
                                <p class="text-sm text-on-surface-variant">Monitor every anomaly in your network with a real-time security monitoring dashboard.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">gpp_maybe</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Proactive Risk Mitigation</h4>
                                <p class="text-sm text-on-surface-variant">Find and patch security holes before attackers have a chance to exploit them.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Methodology -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Security Methodology</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Identify & Assess</h4>
                            <p class="text-sm text-on-surface-variant">Digital asset inventory and risk assessment against potential threats.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Protect & Detect</h4>
                            <p class="text-sm text-on-surface-variant">Implementation of security controls and intrusion detection systems (IDS/IPS).</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Respond & Recover</h4>
                            <p class="text-sm text-on-surface-variant">Developing incident response plans and backup/disaster recovery strategies.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem title="Ecosystem & Deep Integration" description="Our solutions are perfectly designed to connect seamlessly with your existing applications and technology infrastructure." />

    <WhyChooseUs title="Why Choose VeinTech?" subtitle="Our approach isn't just about writing code. We deliver end-to-end business solutions that guarantee ROI, security, and long-term scalability." />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Secure Your Valuable Assets Now."
        description="Don't wait for an incident to occur. Build a resilient cyber defense with our expert team."
        ctaText="Free Security Consultation"
        ctaLink="/en/contact"
    />

    <ServiceBottomSections currentSlug="cyber-security" />

</main>
</BaseLayout>
