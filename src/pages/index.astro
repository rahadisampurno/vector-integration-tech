<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const cards = entry.target.querySelectorAll('.bento-card');
                    cards.forEach((card, index) => {
                        setTimeout(() => {
                            card.classList.remove('opacity-0', 'translate-y-24', 'scale-95');
                        }, index * 250); // More noticeable 250ms gap
                    });
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 }); // Trigger when 20% of the grid wrapper is visible

        const grid = document.getElementById('bento-grid');
        if (grid) observer.observe(grid);
    });
</script>
