---
import { db } from '../../db';
import { products } from '../../db/schema';
import { eq } from 'drizzle-orm';

const { slug, locale } = Astro.props;

// Default dummy for testing
let product = {
  slug: 'veintools-desktop',
  name: 'VeinTools Desktop',
  short_description: 'Asisten bisnis offline untuk membantu UMKM menghitung HPP, membuat invoice, mencatat kas, dan menggunakan berbagai alat bisnis.',
  description: 'VeinTools Desktop adalah aplikasi yang dirancang khusus untuk mempermudah operasional harian UMKM. Tidak perlu koneksi internet (offline), mudah digunakan, dan ringan.',
  category: 'Aplikasi Desktop',
  regular_price: 199000,
  sale_price: null,
  thumbnail_url: '/veintools_logo.png'
};

if (slug) {
  const dbProduct = db.select().from(products).where(eq(products.slug, slug)).get();
  if (dbProduct?.status === 'active') {
    product = dbProduct as any;
  } else if (!dbProduct && slug === 'veintools-desktop') {
    // Keep the legacy fallback product available until it exists in the database.
  } else {
    return Astro.redirect('/produk-digital');
  }
}

const checkoutUrl = `/produk-digital/${product.slug}/pesan`;
const productGallery = Array.from({ length: 29 }, (_, index) =>
  `/produk/${index === 0 ? 'photoproduk' : `photoproduk${index}`}.png`
);
---

