                            <span class="absolute inset-0 w-full h-full bg-white/20 group-hover/btn:translate-x-full transition-transform duration-500 ease-out -translate-x-full skew-x-12"></span>
                            Amankan Sistem
                            <div class="w-10 h-10 bg-black/20 rounded-full flex items-center justify-center group-hover/btn:translate-x-1 transition-transform">
                                <span class="material-symbols-outlined" data-icon="admin_panel_settings">admin_panel_settings</span>
                            </div>
                        </a>
                    </div>
                </div>

            </div>
            
            <!-- Context Indicators -->
            <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-4 z-20">
                <button aria-label="Slide 1" class="w-12 h-1.5 rounded-full bg-white shadow-[0_0_8px_rgba(255,255,255,0.8)] transition-all duration-300 slide-dot-id opacity-100"></button>
                <button aria-label="Slide 2" class="w-4 h-1.5 rounded-full bg-white transition-all duration-300 slide-dot-id opacity-30"></button>
                <button aria-label="Slide 3" class="w-4 h-1.5 rounded-full bg-white transition-all duration-300 slide-dot-id opacity-30"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const slidesContainer = document.getElementById('marketing-slides-id');
        const dots = document.querySelectorAll('.slide-dot-id');
        let currentSlide = 0;
        const totalSlides = 3;

        if (slidesContainer && dots.length > 0) {
            setInterval(() => {
                currentSlide = (currentSlide + 1) % totalSlides;
                slidesContainer.style.transform = `translateX(-${currentSlide * 100}%)`;
                
                dots.forEach((dot, index) => {
                    if(index === currentSlide) {
                        dot.classList.remove('opacity-30', 'w-4');
                        dot.classList.add('opacity-100', 'w-12', 'shadow-[0_0_8px_rgba(255,255,255,0.8)]');
                    } else {
                        dot.classList.remove('opacity-100', 'w-12', 'shadow-[0_0_8px_rgba(255,255,255,0.8)]');
                        dot.classList.add('opacity-30', 'w-4');
                    }
                });
            }, 6000);
        }
    });
</script>
<!-- Services Bento Grid -->
