---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../components/ServiceBottomSections.astro";
---

<BaseLayout title="Architecture & IT Audit | Services">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Services — Consulting
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Architecture <br/><span class="text-primary-fixed-dim">& IT Audit.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    In-depth audit of your IT infrastructure to discover potential cost efficiencies, security gaps, and redesigning architecture for the future.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/en/contact" class="bg-primary-fixed-dim text-white px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Free Consultation <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="IT Audit" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Consulting Services</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">architecture</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Enterprise Architecture</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Large-scale technology architecture design aligned with your long-term business goals.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">analytics</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Cost Optimization</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Analyzing your IT spending (especially Cloud costs) and providing significant savings recommendations.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">fact_check</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Compliance Audit</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Ensuring your IT infrastructure complies with industry standards and data regulations.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Optimizing Infrastructure for Scalability</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Poor IT architecture can be a cost burden and risk for companies. We help you review every technology component for maximum efficiency.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">monetization_on</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Cloud Cost Savings</h4>
                                <p class="text-sm text-on-surface-variant">Many companies waste up to 30% of their Cloud costs. We help you with right-sizing and resource optimization.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">security</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Security Readiness</h4>
                                <p class="text-sm text-on-surface-variant">Identify gaps in architecture that could be entry points for cyber attacks before it's too late.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">rocket_launch</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">System Modernization</h4>
                                <p class="text-sm text-on-surface-variant">Gradual strategy to move from legacy systems to a more flexible modern architecture.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Audit Process -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Audit & Design Process</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Discovery & Inventory</h4>
                            <p class="text-sm text-on-surface-variant">Complete listing of all hardware, software assets, and licenses used by the company.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Gap Analysis</h4>
                            <p class="text-sm text-on-surface-variant">Comparing the current condition with industry standards and your business targets.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Strategic Roadmap</h4>
                            <p class="text-sm text-on-surface-variant">Preparation of an improvement plan and a comprehensive new architecture design.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem title="Ecosystem & Deep Integration" description="Our solutions are perfectly designed to connect seamlessly with your existing applications and technology infrastructure." />

    <WhyChooseUs title="Why Choose VeinTech?" subtitle="Our approach isn't just about writing code. We deliver end-to-end business solutions that guarantee ROI, security, and long-term scalability." />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Start Optimizing Your IT Infrastructure."
        description="Get a clear picture of your technology's condition and find ways to make it more efficient."
        ctaText="Schedule an Audit Now"
        ctaLink="/en/contact"
    />

    <ServiceBottomSections currentSlug="audit-it" />

</main>
</BaseLayout>
