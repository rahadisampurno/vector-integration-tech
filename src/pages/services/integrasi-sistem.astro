---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="Integrasi Sistem | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Integrasi Sistem
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Hancurkan <br/><span class="text-primary-fixed-dim">Silo Data.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Sistem ERP, CRM, database, dan aplikasi warisan Anda berbicara bahasa yang berbeda. Kami adalah penerjemahnya — mengorkestrasi semua platform menjadi satu ekosistem terpadu yang real-time.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Audit Integrasi Gratis <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/5 to-transparent"></div>
                <span class="material-symbols-outlined text-primary-fixed-dim opacity-20" style="font-size: 200px; font-variation-settings: 'FILL' 1;" data-icon="hub">hub</span>
                <div class="absolute bottom-8 left-8 right-8">
                    <div class="bg-surface/80 backdrop-blur-md border border-outline-variant/15 rounded-xl p-4">
                        <div class="flex items-center justify-between text-xs font-mono text-on-surface-variant mb-2">
                            <span>API Sinkronisasi</span>
                            <span class="text-primary-fixed-dim">● Live</span>
                        </div>
                        <div class="flex gap-2 items-center">
                            <div class="text-[10px] bg-primary-fixed-dim/10 text-primary-fixed-dim px-2 py-1 rounded font-mono">ERP</div>
                            <div class="h-px flex-1 bg-primary-fixed-dim/30"></div>
                            <div class="text-[10px] bg-primary-fixed-dim/10 text-primary-fixed-dim px-2 py-1 rounded font-mono">CRM</div>
                            <div class="h-px flex-1 bg-primary-fixed-dim/30"></div>
                            <div class="text-[10px] bg-primary-fixed-dim/10 text-primary-fixed-dim px-2 py-1 rounded font-mono">WA</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Feature Cards -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Kemampuan Integrasi Kami</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="hub" style="font-variation-settings: 'FILL' 1;">hub</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Orkestrasi API (REST & GraphQL)</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Menghubungkan sistem internal dan pihak ketiga melalui lapisan integrasi API yang aman, terdokumentasi, dan dapat dipantau secara real-time.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="sync_alt" style="font-variation-settings: 'FILL' 1;">sync_alt</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Sinkronisasi Data Lintas Platform</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Data pelanggan, inventaris, dan transaksi selalu konsisten di semua platform — tidak ada lagi data yang berbeda antara sistem satu dengan lainnya.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="settings_ethernet" style="font-variation-settings: 'FILL' 1;">settings_ethernet</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Integrasi Sistem Warisan (Legacy)</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Bahkan sistem lama yang sudah berjalan puluhan tahun dapat dihubungkan ke ekosistem modern Anda tanpa perlu mengganti seluruh infrastruktur.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="webhook" style="font-variation-settings: 'FILL' 1;">webhook</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Webhook & Event-Driven Architecture</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Setiap kejadian di sistem Anda — pembayaran masuk, tiket dibuka, stok habis — memicu aksi yang tepat secara otomatis di sistem lain.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="database" style="font-variation-settings: 'FILL' 1;">database</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">ETL & Migrasi Data</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Ekstraksi, transformasi, dan pemuatan data dari sumber lama ke sistem baru tanpa kehilangan satu baris data pun, dijamin akurat dan terverifikasi.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="monitor_heart" style="font-variation-settings: 'FILL' 1;">monitor_heart</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Pemantauan Kesehatan Sistem</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Dashboard monitoring 24/7 yang memantau status semua integrasi aktif dan mengirimkan peringatan segera jika ada yang gagal atau lambat.</p>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="bg-surface-container-low border border-outline-variant/15 rounded-2xl p-12 lg:p-16">
            <div class="mb-12">
                <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Metodologi Integrasi Kami</h2>
                <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">01</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Audit Arsitektur</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Kami memetakan semua sistem yang sedang Anda gunakan, mengidentifikasi titik buta data, dan merancang strategi integrasi yang paling efisien.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">02</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Pembangunan Lapisan Integrasi</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Kami membangun middleware, API gateway, atau konektor kustom yang menghubungkan semua sistem Anda dengan aman dan andal.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">03</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Pengujian & Go-Live</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Setiap alur data diuji secara menyeluruh sebelum diluncurkan ke produksi, memastikan tidak ada gangguan operasional bisnis Anda.</p>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Hentikan Fragmentasi Data Hari Ini."
        description="Hubungi kami untuk audit infrastruktur gratis dan temukan berapa banyak efisiensi yang selama ini tersembunyi di balik silo data Anda."
        ctaText="Minta Audit Gratis"
        
    />

    <ServiceBottomSections currentSlug="integrasi-sistem" />

</main>
</BaseLayout>
