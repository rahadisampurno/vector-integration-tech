---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

interface Props {
  locale?: 'id' | 'en';
}

const lang = Astro.props.locale || Astro.currentLocale || 'id';

const t = lang === 'id' ? {
  title: "IT Architecture Audit & Cloud Optimization",
  subtitle: "Evaluasi menyeluruh terhadap kesehatan arsitektur sistem, efisiensi biaya cloud, serta skalabilitas database untuk menghilangkan bottleneck performa sebelum lonjakan pengguna.",
  category: "SECURE & SCALE",
  badge: "Engineering Audit & Cloud FinOps",
  specs: [
    { label: "Audit Focus Areas", value: "Codebase Health, Database Query Latency, Cloud Cost FinOps & Availability" },
    { label: "Cloud Platforms Evaluated", value: "AWS / Google Cloud (GCP) / Microsoft Azure / Multi-Cloud Kubernetes" },
    { label: "Database Review", value: "PostgreSQL Indexing, Deadlocks, Connection Pooling & N+1 Queries" },
    { label: "Observability Standard", value: "OpenTelemetry / Prometheus / Grafana Metric Integration" },
    { label: "Cost Optimization Target", value: "Average 25% - 45% Monthly Cloud Infrastructure Savings" }
  ],
  deliverables: [
    "Laporan Lengkap Audit Arsitektur IT & Analisis Botteneck Sistem (secara empiris)",
    "Rekomendasi Pemangkasan Biaya Cloud FinOps yang terukur dan aplikatif",
    "Peta jalan refactoring kode dan pengoptimasian query database",
    "Skenario pengujian beban puncak (Stress & Load Testing Blueprint)",
    "Sesi pemaparan eksekutif dan bimbingan teknis bersama tim developer Anda"
  ],
  flow: [
    { step: "01", title: "Infrastructure & Log Ingestion", desc: "Audit metrik penggunaan CPU, memori, latensi query, serta tagihan cloud eksisting." },
    { step: "02", title: "Bottleneck & Cost Diagnosis", desc: "Mengidentifikasi query N+1, overprovisioned instance, dan kebocoran sumber daya." },
    { step: "03", title: "Architectural Hardening", desc: "Perancangan ulang caching, index database, serta auto-scaling kubernetes." },
    { step: "04", title: "Verification & Benchmarking", desc: "Pengujian beban tinggi untuk membuktikan lonjakan throughput dengan biaya cloud lebih rendah." }
  ]
} : {
  title: "IT Architecture Audit & Cloud Optimization",
  subtitle: "Comprehensive end-to-end audit of codebase health, cloud FinOps cost efficiency, and database scalability to eliminate latency bottlenecks.",
  category: "SECURE & SCALE",
  badge: "Engineering Audit & Cloud FinOps",
  specs: [
    { label: "Audit Focus Areas", value: "Codebase Health, Database Query Latency, Cloud Cost FinOps & Availability" },
    { label: "Cloud Platforms Evaluated", value: "AWS / Google Cloud (GCP) / Microsoft Azure / Multi-Cloud Kubernetes" },
    { label: "Database Review", value: "PostgreSQL Indexing, Deadlocks, Connection Pooling & N+1 Queries" },
    { label: "Observability Standard", value: "OpenTelemetry / Prometheus / Grafana Metric Integration" },
    { label: "Cost Optimization Target", value: "Average 25% - 45% Monthly Cloud Infrastructure Savings" }
  ],
  deliverables: [
    "Empirical IT Architecture Audit & Bottleneck Assessment Report",
    "Actionable Cloud FinOps Cost Reduction & Resource Rightsizing Roadmap",
    "Codebase refactoring and PostgreSQL query optimization blueprint",
    "High-concurrency Load & Stress Testing verification benchmarks",
    "Executive debrief and engineering pairing sessions with your technical team"
  ],
  flow: [
    { step: "01", title: "Infrastructure & Log Ingestion", desc: "Auditing CPU, memory, query latency telemetry, and existing cloud spend patterns." },
    { step: "02", title: "Bottleneck & Cost Diagnosis", desc: "Pinpointing N+1 queries, unindexed joins, overprovisioned VMs, and resource leaks." },
    { step: "03", title: "Architectural Hardening", desc: "Redesigning multi-tier caching layers, indexing strategies, and autoscaling thresholds." },
    { step: "04", title: "Verification & Benchmarking", desc: "Stress testing to prove increased throughput at significantly lower infrastructure cost." }
  ]
};
---

<ServiceLayout
  title={t.title}
  subtitle={t.subtitle}
  category={t.category}
  badge={t.badge}
  specs={t.specs}
  deliverables={t.deliverables}
  architectureFlow={t.flow}
>
  <div class="space-y-16">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-2xl sm:text-3xl font-bold font-headline text-slate-900 dark:text-white">
        {lang === 'id' ? 'Mengapa Biaya Cloud Membengkak Saat Sistem Melambat' : 'Why Cloud Costs Surge While Performance Stagnates'}
      </h2>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
        {lang === 'id'
          ? 'Banyak organisasi merespons sistem yang lambat dengan menambah spesifikasi server cloud (vertical scaling), yang memboroskan anggaran bulanan tanpa menyelesaikan akar masalah. Arsitek VEINTECH mengaudit query database, kebocoran memori, dan arsitektur microservices untuk mempercepat respons sistem sekaligus memotong biaya cloud bulanan Anda.'
          : 'Organizations often treat slow performance by buying larger cloud VM instances, bloating monthly bills without fixing the root cause. VEINTECH principal architects audit database indexes, N+1 queries, and microservice coupling to boost system speed while cutting recurring cloud costs.'}
      </p>
    </div>
  </div>
</ServiceLayout>
