<script>
  // Gallery Logic
  function initGallery() {
    const mainImg = document.getElementById('main-preview-img');
    const prevBtn = document.getElementById('prev-slide');
    const nextBtn = document.getElementById('next-slide');
    const thumbs = document.querySelectorAll('.gallery-thumb');
    
    // Lightbox elements
    const lightboxModal = document.getElementById('lightbox-modal');
    const lightboxMainImg = document.getElementById('lightbox-main-img');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    const lightboxThumbs = document.querySelectorAll('.lightbox-thumb');
    const closeLightbox = document.getElementById('close-lightbox');
    
    if (!mainImg || !thumbs.length) return;
    
    let currentIndex = 0;
    
    const updateGallery = (index) => {
      // Bounds
      if (index < 0) index = thumbs.length - 1;
      if (index >= thumbs.length) index = 0;
      
      currentIndex = index;
      
      // Update main image src
      mainImg.src = thumbs[currentIndex].src;
      
      if(lightboxMainImg) {
         lightboxMainImg.src = thumbs[currentIndex].src;
      }
      
      // Update active state of page thumbnails
      thumbs.forEach((th, i) => {
        if (i === currentIndex) {
          th.classList.add('border-blue-500', 'border-2');
          th.classList.remove('border-slate-200', 'dark:border-slate-700', 'border');
        } else {
          th.classList.remove('border-blue-500', 'border-2');
          th.classList.add('border-slate-200', 'dark:border-slate-700', 'border');
        }
      });
      
      // Update active state of lightbox thumbnails
      lightboxThumbs.forEach((th, i) => {
         if (i === currentIndex) {
            th.classList.add('border-blue-500', 'opacity-100');
            th.classList.remove('border-transparent', 'opacity-50');
         } else {
            th.classList.remove('border-blue-500', 'opacity-100');
            th.classList.add('border-transparent', 'opacity-50');
         }
      });
      
      // Scroll thumb into view smoothly if possible
      if (thumbs[currentIndex].scrollIntoView) {
        thumbs[currentIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
      if (lightboxThumbs[currentIndex] && lightboxThumbs[currentIndex].scrollIntoView) {
        lightboxThumbs[currentIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    };

    thumbs.forEach((th, i) => {
      th.addEventListener('click', () => updateGallery(i));
    });
    
    if(lightboxThumbs.length > 0) {
       lightboxThumbs.forEach((th, i) => {
         th.addEventListener('click', () => updateGallery(i));
       });
    }
    
    if (prevBtn) prevBtn.addEventListener('click', () => updateGallery(currentIndex - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => updateGallery(currentIndex + 1));
    if (lightboxPrev) lightboxPrev.addEventListener('click', () => updateGallery(currentIndex - 1));
    if (lightboxNext) lightboxNext.addEventListener('click', () => updateGallery(currentIndex + 1));
    
    // Open Lightbox
    mainImg.parentElement.addEventListener('click', (e) => {
       if(e.target.closest('button')) return; // Ignore if clicked on arrows
       if(lightboxModal) {
         lightboxModal.classList.remove('hidden');
         lightboxModal.classList.add('flex');
         document.body.style.overflow = 'hidden'; // disable page scroll
         updateGallery(currentIndex); // ensure sync
       }
    });
    
    // Close Lightbox
    if(closeLightbox) {
       closeLightbox.addEventListener('click', () => {
         lightboxModal.classList.add('hidden');
         lightboxModal.classList.remove('flex');
         document.body.style.overflow = '';
       });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    initGallery();
  });
  
  document.addEventListener('astro:page-load', () => {
    initGallery();
  });
</script>
