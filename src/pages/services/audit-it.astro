---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="Arsitektur & Audit IT | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Konsultasi
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Arsitektur <br/><span class="text-primary-fixed-dim">& Audit IT.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Audit mendalam terhadap infrastruktur IT Anda untuk menemukan potensi efisiensi biaya, celah keamanan, dan mendesain ulang arsitektur untuk masa depan.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="IT Audit" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Layanan Konsultasi</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">architecture</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Enterprise Architecture</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Desain arsitektur teknologi skala besar yang selaras dengan tujuan bisnis jangka panjang perusahaan Anda.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">analytics</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Cost Optimization</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Menganalisis pengeluaran IT Anda (terutama biaya Cloud) dan memberikan rekomendasi penghematan yang signifikan.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">fact_check</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Compliance Audit</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Memastikan infrastruktur IT Anda mematuhi standar industri dan regulasi data yang berlaku.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Optimasi Infrastruktur untuk Skalabilitas</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Arsitektur IT yang buruk dapat menjadi beban biaya dan risiko bagi perusahaan. Kami membantu Anda meninjau kembali setiap komponen teknologi untuk efisiensi maksimal.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">monetization_on</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Penghematan Biaya Cloud</h4>
                                <p class="text-sm text-on-surface-variant">Banyak perusahaan membuang hingga 30% biaya Cloud mereka. Kami membantu Anda melakukan right-sizing dan optimasi resource.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">security</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Kesiapan Keamanan</h4>
                                <p class="text-sm text-on-surface-variant">Identifikasi celah dalam arsitektur yang bisa menjadi pintu masuk serangan siber sebelum terlambat.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">rocket_launch</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Modernisasi Sistem</h4>
                                <p class="text-sm text-on-surface-variant">Strategi bertahap untuk meninggalkan sistem legacy menuju arsitektur modern yang lebih fleksibel.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Audit Process -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Proses Audit & Desain</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Discovery & Inventory</h4>
                            <p class="text-sm text-on-surface-variant">Pendataan lengkap seluruh aset hardware, software, dan lisensi yang digunakan perusahaan.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Gap Analysis</h4>
                            <p class="text-sm text-on-surface-variant">Membandingkan kondisi saat ini dengan standar industri dan target bisnis Anda.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Strategic Roadmap</h4>
                            <p class="text-sm text-on-surface-variant">Penyusunan rencana perbaikan dan desain arsitektur baru yang komprehensif.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Mulai Optimasi Infrastruktur IT Anda."
        description="Dapatkan gambaran jelas mengenai kondisi teknologi Anda dan temukan cara untuk membuatnya lebih efisien."
        ctaText="Jadwalkan Audit Sekarang"
        
    />

    <ServiceBottomSections currentSlug="audit-it" />

</main>
</BaseLayout>
