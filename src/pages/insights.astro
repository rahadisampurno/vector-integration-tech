---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Insights">
	<section class="insights-hero">
		<div class="container text-center">
			<span class="badge">Deep Dives</span>
			<h1>Technology <span class="highlight">Insights</span></h1>
			<p>Staying ahead of the curve with experts from VEINTECH.</p>
		</div>
	</section>

	<section class="insights-grid section">
		<div class="container grid-3">
			<div class="insight-card glass fade-in">
				<span class="date">Oct 12, 2026</span>
				<h3>The Future of Multi-Agent AI Systems</h3>
				<p>Exploring how autonomous agents are redefining enterprise productivity.</p>
				<a href="#" class="read-more">Read More →</a>
			</div>
			<div class="insight-card glass fade-in">
				<span class="date">Sep 28, 2026</span>
				<h3>Security in System Integration</h3>
				<p>Best practices for maintaining data integrity in complex API ecosystems.</p>
				<a href="#" class="read-more">Read More →</a>
			</div>
			<div class="insight-card glass fade-in">
				<span class="date">Sep 15, 2026</span>
				<h3>Astro vs. Next.js for Corporate Sites</h3>
				<p>Why performance is the new SEO gold standard in 2026.</p>
				<a href="#" class="read-more">Read More →</a>
			</div>
		</div>
	</section>

	<style>
		.insights-hero {
			padding: 160px 0 80px;
			background: var(--bg-alt);
		}

		.grid-3 {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
			gap: 30px;
		}

		.insight-card {
			padding: 30px;
			border-radius: 20px;
		}

		.date {
			font-size: 0.8rem;
			color: var(--text-muted);
		}

		.insight-card h3 {
			margin: 15px 0;
		}

		.read-more {
			display: inline-block;
			margin-top: 20px;
			color: var(--accent-blue);
			text-decoration: none;
			font-weight: 600;
		}
	</style>
</BaseLayout>
