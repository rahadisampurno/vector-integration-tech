---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="SaaS & Web Development | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Pengembangan
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    SaaS & Web <br/><span class="text-primary-fixed-dim">Development.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Merancang dan membangun platform SaaS berbasis web yang responsif, cepat, dan siap diskalakan sesuai pertumbuhan pengguna global Anda.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-white px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="SaaS Development" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Layanan Pengembangan</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">web</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Custom Web Apps</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Aplikasi web kustom dengan fitur kompleks yang dibangun khusus untuk kebutuhan bisnis Anda.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">layers</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Arsitektur Multi-tenant</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Desain database dan sistem yang aman untuk mendukung ribuan penyewa (tenants) dalam satu platform SaaS.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">speed</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Performa & Skalabilitas</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Optimalisasi kecepatan muat dan kemampuan sistem untuk menangani lonjakan trafik tanpa kendala.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Membangun Platform SaaS yang Tangguh</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Ubah ide bisnis Anda menjadi produk digital yang siap pakai. Kami menggunakan teknologi terbaru untuk memastikan aplikasi Anda cepat, aman, dan mudah dikelola.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">devices</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">UI/UX Modern & Responsif</h4>
                                <p class="text-sm text-on-surface-variant">Desain antarmuka yang intuitif dan berfungsi sempurna di berbagai ukuran layar perangkat.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">code</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Clean Code & Dokumentasi</h4>
                                <p class="text-sm text-on-surface-variant">Penulisan kode yang rapi dan terdokumentasi dengan baik memudahkan pengembangan di masa depan.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">cloud_upload</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">CI/CD & DevOps</h4>
                                <p class="text-sm text-on-surface-variant">Otomatisasi deployment untuk memastikan fitur baru dapat dirilis dengan cepat dan tanpa bug.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Process -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Fase Pengembangan</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Prototyping & Design</h4>
                            <p class="text-sm text-on-surface-variant">Pembuatan wireframe dan desain high-fidelity (UI) sebelum tahap pengkodean.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Agile Development</h4>
                            <p class="text-sm text-on-surface-variant">Pengembangan dalam sprint pendek untuk memastikan progres yang transparan dan adaptif.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-white flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">QA & Launch</h4>
                            <p class="text-sm text-on-surface-variant">Pengujian fungsionalitas dan keamanan secara menyeluruh sebelum peluncuran resmi.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Wujudkan Platform SaaS Impian Anda."
        description="Dari ide mentah hingga produk yang siap dikomersilkan. Mari bangun masa depan digital bersama."
        ctaText="Mulai Diskusi Proyek"
        
    />

    <ServiceBottomSections currentSlug="saas-web-dev" />

</main>
</BaseLayout>
