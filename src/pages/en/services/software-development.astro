---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../../components/ServiceBottomSections.astro";
---

<BaseLayout title="Software Development | Services">
<main class="pt-32 pb-20">

    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Services — Software Development
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Build Your <br/><span class="text-primary-fixed-dim">Digital Product.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    From stunning websites to intuitive mobile apps and enterprise-grade SaaS systems — we build scalable, secure digital products built to last.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/en/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Discuss Your Project <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/5 to-transparent"></div>
                <span class="material-symbols-outlined text-primary-fixed-dim opacity-20" style="font-size: 200px; font-variation-settings: 'FILL' 1;" data-icon="terminal">terminal</span>
            </div>
        </div>
    </header>

    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">What We Build</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="language" style="font-variation-settings: 'FILL' 1;">language</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Corporate Websites & Landing Pages</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Modern, fast, and SEO-friendly designs that reflect your brand's professionalism and convert visitors into active prospects.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="phone_android" style="font-variation-settings: 'FILL' 1;">phone_android</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">iOS & Android Mobile Apps</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Native and cross-platform apps that are responsive, intuitive, and ready for the App Store and Google Play with high performance.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="cloud_done" style="font-variation-settings: 'FILL' 1;">cloud_done</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Enterprise SaaS Systems</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Software-as-a-Service platforms with multi-tenant architecture, subscription management, and cloud infrastructure ready for thousands of users.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Internal Management Systems</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Custom admin panels, HR systems, inventory management, or ERP designed specifically for your organisation's unique workflows.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="memory" style="font-variation-settings: 'FILL' 1;">memory</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Embedded Systems & IoT</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Firmware and software for custom hardware — from industrial sensors to IoT gateways connected to the cloud.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="api" style="font-variation-settings: 'FILL' 1;">api</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Backend API & Microservices</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Modular, fully documented backend architecture ready to connect to any mobile app, web app, or third-party system.</p>
            </div>
        </div>
    </section>

    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="bg-surface-container-low border border-outline-variant/15 rounded-2xl p-12 lg:p-16">
            <div class="mb-12">
                <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Our Development Process</h2>
                <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center"><span class="font-headline font-bold text-primary-fixed-dim text-lg">01</span></div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Discovery & Architecture</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">We discuss your product vision, user needs, and business requirements to design the right technical blueprint.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center"><span class="font-headline font-bold text-primary-fixed-dim text-lg">02</span></div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Iterative Development</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Using Agile methodology with 2-week sprints — you see real progress every two weeks and provide direct feedback.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center"><span class="font-headline font-bold text-primary-fixed-dim text-lg">03</span></div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Testing & Launch</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Comprehensive QA including security, performance, and device compatibility testing, followed by launch and post-release support.</p>
                </div>
            </div>
        </div>
    </section>

    <ServiceEcosystem title="Ecosystem & Deep Integration" description="Our solutions are perfectly designed to connect seamlessly with your existing applications and technology infrastructure." />

    <WhyChooseUs title="Why Choose VeinTech?" subtitle="Our approach isn't just about writing code. We deliver end-to-end business solutions that guarantee ROI, security, and long-term scalability." />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Have an Idea? Let's Build It Together."
        description="Tell us about the product you want to build. We'll provide a clear estimate and development roadmap — no upfront consulting fees."
        ctaText="Discuss Your Project Now"
        ctaLink="/en/contact"
    />

    <ServiceBottomSections currentSlug="software-development" />

</main>
</BaseLayout>
