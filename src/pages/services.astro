                <!-- SaaS & Web Dev -->
                <a href="/services/saas-web-dev" data-category="development business enterprise" class="service-card group/item flex flex-col bg-white dark:bg-white/5 border border-outline-variant/10 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary-fixed-dim/10 hover:-translate-y-2 transition-all duration-500 animate-reveal delay-[300ms]">
