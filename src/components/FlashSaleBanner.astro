---
interface Props {
  discount?: string;
  hours?: number;
  minutes?: number;
}

const { discount = "50%", hours = 47, minutes = 30 } = Astro.props;

// Total seconds for the cycle
const totalSeconds = (hours * 3600) + (minutes * 60);
---

<div class="w-full bg-gradient-to-r from-red-600 via-orange-500 to-amber-500 text-white py-4 px-6 relative overflow-hidden shadow-2xl z-50">
    <!-- Animated background patterns -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent animate-pulse"></div>
    </div>

    <div class="max-w-[1440px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4 relative z-10">
        <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-white/30 animate-bounce">
                <span class="material-symbols-outlined text-white font-bold">bolt</span>
            </div>
            <div>
                <h3 class="text-xl md:text-2xl font-headline font-black tracking-tighter uppercase leading-none">
                    Flash Sale <span class="text-yellow-300">DISKON {discount}</span>
                </h3>
                <p class="text-xs md:text-sm font-body font-medium text-white/90">Penawaran terbatas untuk Website UMKM & Bisnis!</p>
            </div>
        </div>

        <div class="flex items-center gap-4 bg-black/20 backdrop-blur-xl px-6 py-2 rounded-2xl border border-white/10">
            <span class="text-[10px] font-label font-bold tracking-widest uppercase text-white/70">Berakhir Dalam:</span>
            <div id="countdown-timer" class="flex items-center gap-3 font-mono text-xl md:text-2xl font-bold" data-total-seconds={totalSeconds}>
                <div class="flex flex-col items-center">
                    <span id="hours" class="bg-white text-red-600 px-2 py-1 rounded-lg min-w-[44px] text-center shadow-inner">47</span>
                    <span class="text-[8px] mt-1 text-white/70 font-label uppercase">Jam</span>
                </div>
                <span class="text-white animate-pulse">:</span>
                <div class="flex flex-col items-center">
                    <span id="minutes" class="bg-white text-red-600 px-2 py-1 rounded-lg min-w-[44px] text-center shadow-inner">30</span>
                    <span class="text-[8px] mt-1 text-white/70 font-label uppercase">Menit</span>
                </div>
                <span class="text-white animate-pulse">:</span>
                <div class="flex flex-col items-center">
                    <span id="seconds" class="bg-white text-red-600 px-2 py-1 rounded-lg min-w-[44px] text-center shadow-inner">00</span>
                    <span class="text-[8px] mt-1 text-white/70 font-label uppercase">Detik</span>
                </div>
            </div>
        </div>

        <a href="#pricing" class="bg-white text-red-600 px-8 py-3 rounded-full font-headline font-black text-sm uppercase hover:bg-yellow-300 hover:scale-105 transition-all shadow-xl shadow-black/20">
            Ambil Promo
        </a>
    </div>
</div>

<script>
    function startCountdown() {
        const timerContainer = document.getElementById('countdown-timer');
        if (!timerContainer) return;

        const totalCycleSeconds = parseInt(timerContainer.dataset.totalSeconds || "171000");
        const cycleMs = totalCycleSeconds * 1000;

        const hoursEl = document.getElementById('hours');
        const minutesEl = document.getElementById('minutes');
        const secondsEl = document.getElementById('seconds');

        function update() {
            const now = Date.now();
            // Use a fixed epoch (e.g., 2024-01-01) or just current time modulo cycle
            // To make it look like a real countdown that everyone sees the same
            const remainingMs = cycleMs - (now % cycleMs);
            const remainingSeconds = Math.floor(remainingMs / 1000);

            const h = Math.floor(remainingSeconds / 3600);
            const m = Math.floor((remainingSeconds % 3600) / 60);
            const s = remainingSeconds % 60;

            if (hoursEl) hoursEl.textContent = h.toString().padStart(2, '0');
            if (minutesEl) minutesEl.textContent = m.toString().padStart(2, '0');
            if (secondsEl) secondsEl.textContent = s.toString().padStart(2, '0');
        }

        setInterval(update, 1000);
        update();
    }

    // Run on load and after swaps (if using ViewTransitions)
    document.addEventListener('astro:page-load', startCountdown);
    // Initial run
    startCountdown();
</script>

<style>
    @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    .shimmer {
        position: relative;
        overflow: hidden;
    }
    .shimmer::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.2),
            transparent
        );
        animation: shimmer 2s infinite;
    }
</style>
