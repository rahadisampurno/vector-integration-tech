---
import BaseLayout from '../layouts/BaseLayout.astro';

const techStack = [
  { icon: 'memory', label: 'Pusat AI' },
  { icon: 'cloud', label: 'Cloud Native' },
  { icon: 'forum', label: 'Orkestrasi API WhatsApp' },
  { icon: 'api', label: 'Integrasi API' },
  { icon: 'settings_slow_motion', label: 'Otomatisasi' },
  { icon: 'database', label: 'Rekayasa Data' },
  { icon: 'security', label: 'Keamanan Zero Trust' },
  { icon: 'hub', label: 'Komputasi Edge' },
  { icon: 'swap_calls', label: 'Sistem Terintegrasi' },
  { icon: 'insights', label: 'Analisis Prediktif' }
];
---

<BaseLayout title="Home">
<!-- Hero Section -->
<section class="relative min-h-[100vh] pt-32 pb-16 flex items-center overflow-hidden">
<div class="absolute inset-0 z-0">
<img class="w-full h-full object-cover opacity-30" data-alt="abstract digital data streams and network nodes glowing in deep blue and cyan space background with motion blur" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAdfWCdm-XRiLaDDHo3Rpky51iJmFxsQBQDM_6zxMTubJaChKbKz1qxOmJz5YEii2XgVQCX0tBzbBGAIGq84iXEufq_HTm1O2kRCyH4-ghzRLGt4YP6KGhoGxVG4ORDCOwqlkhYarYRplu8sOgu6M2F8ymB-AFRZuruF3yx5WLLtBPC1vSeVYdF-sKlv8W7n0HYyEmK3WxznkuzwsR58ksK2dFvdsEKwONlrKRJyebBhoqm8_yp1pMxYHVZ0Lvqxf3txpvaW3mughhc"/>
<div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface"></div>
</div>
<div class="relative z-10 max-w-[1440px] mx-auto px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center w-full">
<div class="space-y-8">
<div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container/30 border border-outline-variant/15 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase">
<span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
                    Sekarang Mengintegrasikan Sistem Masa Depan
                </div>
<h1 class="text-5xl md:text-6xl xl:text-7xl font-bold leading-[1.05] tracking-tighter font-headline text-slate-900 dark:text-white break-words relative z-20">
                    Meningkatkan Produktivitas dan Efisiensi <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed-dim to-on-primary-container">Alur Kerja Anda.</span>
</h1>
<p id="hero-desc-carousel" class="text-on-surface-variant text-lg leading-relaxed max-w-lg mt-6 min-h-[90px] transition-opacity duration-500">
                    Menyatukan berbagai perangkat lunak bisnis Anda ke dalam satu alur kerja otomatis.
                </p>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const lines = [
            "Menyatukan berbagai perangkat lunak bisnis Anda ke dalam satu alur kerja otomatis.",
            "Menghadirkan Kecerdasan Buatan (AI) ke dalam sistem Anda untuk operasional yang lebih cerdas.",
            "Melindungi seluruh data perusahaan dengan pondasi keamanan siber tingkat tinggi (Zero Trust)."
        ];
        let i = 0;
        const el = document.getElementById("hero-desc-carousel");
        if(el) {
            setInterval(() => {
                el.style.opacity = '0';
                setTimeout(() => {
                    i = (i + 1) % lines.length;
                    el.textContent = lines[i];
                    el.style.opacity = '1';
                }, 500); 
            }, 4000); 
        }
    });
</script>
<div class="flex flex-wrap gap-4">
<button class="bg-gradient-to-br from-primary-fixed-dim to-on-primary-container text-on-primary-fixed px-8 py-4 rounded-lg font-bold font-headline shadow-lg shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 transition-all hover:-translate-y-1 hover:brightness-110 flex items-center justify-center gap-2 group w-full md:w-auto">
                        Konsultasi Sekarang
                        <span class="material-symbols-outlined transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
</button>
<a href="/services" class="bg-surface-container-highest border border-primary/15 text-slate-900 dark:text-white font-bold px-8 py-4 rounded-lg hover:bg-surface-container-high transition-all flex items-center justify-center">
                        Lihat Layanan
                    </a>
</div>
</div>
<div class="hidden lg:block relative">
<div class="absolute -inset-4 bg-primary-fixed-dim/5 blur-3xl rounded-full"></div>
<div class="relative bg-surface-container-low border border-outline-variant/15 p-8 rounded-xl backdrop-blur-md">
<div class="grid grid-cols-2 gap-4">
<div class="aspect-square bg-surface-container-highest/50 rounded-lg flex flex-col justify-between p-6 group hover:bg-surface-container-high transition-all node-indicator relative">
<div class="flex items-start justify-between w-full">
<span class="material-symbols-outlined text-primary-fixed-dim text-2xl transform group-hover:-translate-y-1 group-hover:scale-110 transition-transform" data-icon="hub">hub</span>
<span class="text-[10px] font-mono text-outline-variant font-bold tracking-widest opacity-50">01</span>
</div>
<div>
<span class="font-headline font-bold text-slate-900 dark:text-white uppercase text-[11px] tracking-widest block mb-2">Konektivitas</span>
<span class="text-[10px] text-on-surface-variant leading-relaxed block group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">Menghubungkan ratusan sistem IT menjadi satu antarmuka via API.</span>
</div>
</div>
<div class="aspect-square bg-surface-container-highest/50 rounded-lg flex flex-col justify-between p-6 group hover:bg-surface-container-high transition-all">
<div class="flex items-start justify-between w-full">
<span class="material-symbols-outlined text-primary-fixed-dim text-2xl transform group-hover:-translate-y-1 group-hover:scale-110 transition-transform" data-icon="psychology">psychology</span>
<span class="text-[10px] font-mono text-outline-variant font-bold tracking-widest opacity-50">02</span>
</div>
<div>
<span class="font-headline font-bold text-slate-900 dark:text-white uppercase text-[11px] tracking-widest block mb-2">Kecerdasan</span>
<span class="text-[10px] text-on-surface-variant leading-relaxed block group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">Mesin AI analitik prediktif untuk keputusan bisnis presisi tinggi.</span>
</div>
</div>
<div class="aspect-square bg-surface-container-highest/50 rounded-lg flex flex-col justify-between p-6 group hover:bg-surface-container-high transition-all">
<div class="flex items-start justify-between w-full">
<span class="material-symbols-outlined text-primary-fixed-dim text-2xl transform group-hover:-translate-y-1 group-hover:scale-110 transition-transform" data-icon="settings_input_component">settings_input_component</span>
<span class="text-[10px] font-mono text-outline-variant font-bold tracking-widest opacity-50">03</span>
</div>
<div>
<span class="font-headline font-bold text-slate-900 dark:text-white uppercase text-[11px] tracking-widest block mb-2">Otomatisasi</span>
<span class="text-[10px] text-on-surface-variant leading-relaxed block group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">Menyulap tugas repetitif manual menjadi alur kerja secepat kilat.</span>
</div>
</div>
<div class="aspect-square bg-surface-container-highest/50 rounded-lg flex flex-col justify-between p-6 group hover:bg-surface-container-high transition-all node-indicator relative">
<div class="flex items-start justify-between w-full">
<span class="material-symbols-outlined text-primary-fixed-dim text-2xl transform group-hover:-translate-y-1 group-hover:scale-110 transition-transform" data-icon="shield">shield</span>
<span class="text-[10px] font-mono text-outline-variant font-bold tracking-widest opacity-50">04</span>
</div>
<div>
<span class="font-headline font-bold text-slate-900 dark:text-white uppercase text-[11px] tracking-widest block mb-2">Keamanan Zero Trust</span>
<span class="text-[10px] text-on-surface-variant leading-relaxed block group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">Infrastruktur tangguh pro-kepatuhan hukum UU PDP Indonesia.</span>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Marketing Banner Section -->
<section class="py-12 bg-surface-container-lowest overflow-hidden border border-outline-variant/15 relative">
    <div class="max-w-[1440px] mx-auto px-12 relative z-10">
        <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-surface-container-high to-surface-container border border-outline-variant/15 group">
            <!-- Decorative Background Element -->
            <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary-fixed-dim/10 to-transparent pointer-events-none"></div>
            
            <!-- Slides Container -->
            <div class="flex transition-transform duration-700 ease-in-out" id="marketing-slides-id">
                <!-- Slide 1 -->
                <div class="min-w-full flex-shrink-0 p-8 md:p-12 lg:p-16 flex flex-col md:flex-row items-center justify-between gap-8 h-auto md:h-64">
                    <div class="max-w-2xl">
                        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 text-primary-fixed-dim font-bold text-xs uppercase tracking-widest rounded-full mb-6">
                            <span class="w-1.5 h-1.5 rounded-full bg-primary-fixed-dim animate-pulse"></span>
                            Penawaran Terbatas
                        </div>
                        <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-4 leading-tight">Audit Infrastruktur IT Gratis</h2>
                        <p class="text-on-surface-variant">Dapatkan analisis mendalam tentang keamanan dan efisiensi sistem Anda oleh pakar arsitektur kami, tanpa biaya sepeser pun.</p>
                    </div>
                    <a href="/contact" class="flex-shrink-0 bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all shadow-lg shadow-primary-fixed-dim/20 flex items-center gap-2 lg:group-hover:scale-105">
                        Klaim Audit Sekarang <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                </div>
                <!-- Slide 2 -->
                <div class="min-w-full flex-shrink-0 p-8 md:p-12 lg:p-16 flex flex-col md:flex-row items-center justify-between gap-8 h-auto md:h-64">
                    <div class="max-w-2xl">
                        <div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary/10 text-secondary font-bold text-xs uppercase tracking-widest rounded-full mb-6">
                            <span class="w-1.5 h-1.5 rounded-full bg-secondary animate-pulse"></span>
                            Program Akselerasi
                        </div>
                        <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-4 leading-tight">Pembuktian ROI Otomatisasi</h2>
                        <p class="text-on-surface-variant">Kami akan mengotomatiskan satu proses bisnis terberat Anda secara gratis untuk membuktikan efisiensi eksponensial.</p>
                    </div>
                    <a href="/contact" class="flex-shrink-0 bg-surface-container-highest border border-primary/20 text-slate-900 dark:text-white px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all flex items-center gap-2 lg:group-hover:scale-105">
                        Mulai Percobaan <span class="material-symbols-outlined" data-icon="settings_slow_motion">settings_slow_motion</span>
                    </a>
                </div>
                <!-- Slide 3 -->
                <div class="min-w-full flex-shrink-0 p-8 md:p-12 lg:p-16 flex flex-col md:flex-row items-center justify-between gap-8 h-auto md:h-64">
                    <div class="max-w-2xl">
                        <div class="inline-flex items-center gap-2 px-3 py-1 bg-error/10 text-error font-bold text-xs uppercase tracking-widest rounded-full mb-6">
                            <span class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span>
                            Kepatuhan Regulasi
                        </div>
                        <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-4 leading-tight">Konsultasi Kesiapan UU PDP</h2>
                        <p class="text-on-surface-variant">Pastikan tumpukan teknologi Anda 100% mematuhi hukum privasi data Indonesia sebelum tenggat waktu diperketat.</p>
                    </div>
                    <a href="/contact" class="flex-shrink-0 bg-slate-900 text-white dark:bg-white dark:text-slate-900 px-8 py-4 rounded-xl font-headline font-bold hover:opacity-90 transition-all flex items-center gap-2 lg:group-hover:scale-105">
                        Amankan Sistem <span class="material-symbols-outlined" data-icon="shield_locked">shield_locked</span>
                    </a>
                </div>
            </div>
            
            <!-- Context Indicators -->
            <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-3 z-20">
                <button aria-label="Slide 1" class="w-2 h-2 rounded-full bg-primary-fixed-dim transition-all duration-300 slide-dot-id opacity-100 scale-150"></button>
                <button aria-label="Slide 2" class="w-2 h-2 rounded-full bg-primary-fixed-dim transition-all duration-300 slide-dot-id opacity-30"></button>
                <button aria-label="Slide 3" class="w-2 h-2 rounded-full bg-primary-fixed-dim transition-all duration-300 slide-dot-id opacity-30"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const slidesContainer = document.getElementById('marketing-slides-id');
        const dots = document.querySelectorAll('.slide-dot-id');
        let currentSlide = 0;
        const totalSlides = 3;

        if (slidesContainer && dots.length > 0) {
            setInterval(() => {
                currentSlide = (currentSlide + 1) % totalSlides;
                slidesContainer.style.transform = `translateX(-${currentSlide * 100}%)`;
                
                dots.forEach((dot, index) => {
                    if(index === currentSlide) {
                        dot.classList.remove('opacity-30');
                        dot.classList.add('opacity-100', 'scale-150');
                    } else {
                        dot.classList.remove('opacity-100', 'scale-150');
                        dot.classList.add('opacity-30');
                    }
                });
            }, 6000);
        }
    });
</script>
<!-- Services Bento Grid -->
<section class="py-24 bg-surface">
<div class="max-w-[1440px] mx-auto px-12">
<div class="mb-16">
<h2 class="text-4xl md:text-6xl font-bold font-headline tracking-tighter text-slate-900 dark:text-white mb-6">Kemampuan Inti Kami</h2>
<div class="w-24 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-12 gap-4">
<div class="md:col-span-8 bg-surface-container-low rounded-xl p-10 flex flex-col justify-between group hover:bg-surface-container-high transition-all relative overflow-hidden border border-outline-variant/15">
<div class="relative z-10">
<span class="material-symbols-outlined text-4xl text-primary-fixed-dim mb-6" data-icon="bolt">bolt</span>
<h3 class="text-3xl font-bold font-headline text-slate-900 dark:text-white mb-4">Solusi AI &amp; Otomatisasi</h3>
<p class="text-on-surface-variant max-w-md">Mendorong produktivitas bisnis dengan alur kerja AI yang disesuaikan untuk belajar dan beradaptasi dengan lingkungan operasional unik Anda.</p>
</div>
<div class="absolute right-0 bottom-0 w-1/3 opacity-10 group-hover:opacity-20 transition-opacity">
<span class="material-symbols-outlined text-[12rem]" data-icon="smart_toy">smart_toy</span>
</div>
</div>
<div class="md:col-span-4 bg-surface-container-low rounded-xl p-10 group hover:bg-surface-container-high transition-all node-indicator relative border border-outline-variant/15">
<span class="material-symbols-outlined text-4xl text-primary-fixed-dim mb-6" data-icon="integration_instructions">integration_instructions</span>
<h3 class="text-xl font-bold font-headline text-slate-900 dark:text-white mb-4 uppercase tracking-wider">Integrasi Sistem</h3>
<p class="text-on-surface-variant text-sm">Menjembatani ekosistem tanpa hambatan. Kami menghubungkan tumpukan perangkat lunak yang berbeda ke dalam satu sistem yang terpadu.</p>
</div>
<div class="md:col-span-4 bg-surface-container-low rounded-xl p-10 group hover:bg-surface-container-high transition-all border border-outline-variant/15">
<span class="material-symbols-outlined text-4xl text-primary-fixed-dim mb-6" data-icon="lan">lan</span>
<h3 class="text-xl font-bold font-headline text-slate-900 dark:text-white mb-4 uppercase tracking-wider">Infrastruktur Digital</h3>
<p class="text-on-surface-variant text-sm">Fondasi masa depan yang dibangun di atas arsitektur cloud yang terukur dan kerangka komputasi edge yang tangguh.</p>
</div>
<div class="md:col-span-8 bg-surface-container-low rounded-xl p-10 flex items-center gap-12 group hover:bg-surface-container-high transition-all relative border border-outline-variant/15">
<div class="flex-1">
<span class="material-symbols-outlined text-4xl text-primary-fixed-dim mb-6" data-icon="query_stats">query_stats</span>
<h3 class="text-3xl font-bold font-headline text-slate-900 dark:text-white mb-4">Konsultasi IT</h3>
<p class="text-on-surface-variant">Peta jalan strategis untuk transformasi digital, difokuskan pada memaksimalkan ROI dan ketahanan operasional.</p>
</div>
<div class="hidden lg:block w-48 h-48 bg-surface-container-highest rounded-full border border-outline-variant/15 flex items-center justify-center">
<span class="material-symbols-outlined text-6xl text-primary/40 animate-spin" data-icon="cyclone" style="animation-duration: 10s">cyclone</span>
</div>
</div>
</div>
</div>
</section>
<!-- Why Choose VEIN Section -->
<section class="py-24 bg-surface-container-lowest border border-outline-variant/15">
<div class="max-w-[1440px] mx-auto px-12 flex flex-col lg:flex-row gap-20">
<div class="lg:w-1/3">
<div class="sticky top-32">
<h2 class="text-4xl md:text-6xl font-bold font-headline tracking-tighter text-slate-900 dark:text-white mb-8">Mengapa Kecerdasan Itu Penting</h2>
<p class="text-on-surface-variant leading-relaxed">
                        Di era data kinetik, integrasi statis tidaklah cukup. Kami membangun sistem yang merasakan, berpikir, dan berkembang.
                    </p>
</div>
</div>
<div class="lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-16">
<div class="space-y-4">
<div class="flex items-center gap-4 text-primary-fixed-dim">
<span class="text-xs font-bold font-headline">01</span>
<div class="flex-1 h-px bg-outline-variant/30"></div>
</div>
<h4 class="text-2xl font-bold font-headline text-slate-900 dark:text-white">Tim Ahli</h4>
<p class="text-on-surface-variant text-sm leading-relaxed">Insinyur dan ilmuwan data berlatar belakang kelas dunia, berdedikasi memecahkan tantangan arsitektur yang kompleks.</p>
</div>
<div class="space-y-4">
<div class="flex items-center gap-4 text-primary-fixed-dim">
<span class="text-xs font-bold font-headline">02</span>
<div class="flex-1 h-px bg-outline-variant/30"></div>
</div>
<h4 class="text-2xl font-bold font-headline text-slate-900 dark:text-white">Arsitektur Skalabel</h4>
<p class="text-on-surface-variant text-sm leading-relaxed">Skalabilitas horizontal tertanam dalam setiap baris kode, memastikan sistem Anda berkembang secepat ambisi Anda.</p>
</div>
<div class="space-y-4">
<div class="flex items-center gap-4 text-primary-fixed-dim">
<span class="text-xs font-bold font-headline">03</span>
<div class="flex-1 h-px bg-outline-variant/30"></div>
</div>
<h4 class="text-2xl font-bold font-headline text-slate-900 dark:text-white">Solusi Berbasis AI</h4>
<p class="text-on-surface-variant text-sm leading-relaxed">Kami memanfaatkan jaringan saraf nalar dan pembelajaran mesin untuk mengotomatisasi jalur keputusan, bukan hanya pekerjaan berulang.</p>
</div>
<div class="space-y-4">
<div class="flex items-center gap-4 text-primary-fixed-dim">
<span class="text-xs font-bold font-headline">04</span>
<div class="flex-1 h-px bg-outline-variant/30"></div>
</div>
<h4 class="text-2xl font-bold font-headline text-slate-900 dark:text-white">Otomatisasi Khusus</h4>
<p class="text-on-surface-variant text-sm leading-relaxed">Alur kerja khusus dirancang untuk tumpukan teknologi Anda, memastikan tidak ada hambatan dalam proses integrasi.</p>
</div>
</div>
</div>
</section>
<!-- Tech Stack Logos -->
<section class="py-24 bg-surface border-t border-outline-variant/5">
<div class="max-w-[1440px] mx-auto px-12">
<h3 class="text-center font-headline text-3xl font-bold text-slate-900 dark:text-white mb-16">Tumpukan Teknologi VEINTECH</h3>
<div class="relative w-full overflow-hidden flex group py-4">
    <div class="absolute inset-y-0 left-0 w-20 md:w-40 bg-gradient-to-r from-surface to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-20 md:w-40 bg-gradient-to-l from-surface to-transparent z-10 pointer-events-none"></div>

    <div class="flex animate-marquee group-hover:[animation-play-state:paused] items-center w-max">
        {[1, 2].map(() => (
            <div class="flex items-center gap-16 md:gap-32 px-8 md:px-16">
                {techStack.map((tech) => (
                    <div class="flex flex-col items-center gap-4 hover:scale-110 transition-transform duration-300">
                        <span class="material-symbols-outlined text-5xl md:text-6xl text-primary/40 dark:text-primary/60 transition-colors" data-icon={tech.icon}>{tech.icon}</span>
                        <span class="text-xs font-label uppercase tracking-widest text-slate-500 whitespace-nowrap">{tech.label}</span>
                    </div>
                ))}
            </div>
        ))}
    </div>
</div>
</div>
</section>
</BaseLayout>
