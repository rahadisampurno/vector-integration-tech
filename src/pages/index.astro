        <div class="relative overflow-hidden rounded-[2.5rem] border border-outline-variant/20 shadow-2xl group w-full bg-slate-950">
            <!-- Slides Container -->
            <div class="flex transition-transform duration-1000 ease-in-out h-full" id="marketing-slides-id">
                
                <!-- Slide 1: AI (Indigo/Cyan Mesh) -->
