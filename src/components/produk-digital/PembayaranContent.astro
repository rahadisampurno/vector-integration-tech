---
import { db } from '../../db';
import { orders, products, paymentAccounts } from '../../db/schema';
import { asc, eq } from 'drizzle-orm';

const { orderCode } = Astro.props;

if (!orderCode) {
  return Astro.redirect('/produk-digital/cari-pesanan');
}

const order = await db.select().from(orders).where(eq(orders.order_code, orderCode)).get();

if (!order) {
  return Astro.redirect('/produk-digital/cari-pesanan');
}

const product = await db.select().from(products).where(eq(products.id, order.product_id)).get();

// Payment Methods
const paymentMethods = await db.select().from(paymentAccounts).where(eq(paymentAccounts.status, 'active')).orderBy(asc(paymentAccounts.sort_order)).all();

// Calculate expired time (24 hours from creation)
const expiredAt = new Date(new Date(order.created_at).getTime() + 24 * 60 * 60 * 1000);
const formattedExpired = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric', month: 'long', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZoneName: 'short'
}).format(expiredAt);

const subtotalAmount = order.subtotal_amount || product?.sale_price || product?.regular_price || 0;
const discountAmount = order.discount_amount || 0;
const uniqueAmount = order.total_amount - subtotalAmount + discountAmount;
---

<section class="pt-32 pb-24 bg-surface min-h-screen text-on-surface">
  <div class="max-w-3xl mx-auto px-6 md:px-12">
    
    <div class="text-center mb-8">
      <h1 class="text-3xl font-headline font-bold mb-2">Instruksi Pembayaran</h1>
      <p class="text-on-surface-variant">Selesaikan pembayaran sebelum batas waktu berakhir.</p>
    </div>

    {order.status === 'WAITING_PAYMENT' ? (
      <div class="bg-surface-container border border-outline-variant/30 rounded-2xl overflow-hidden shadow-sm mb-8">
        <!-- Header -->
        <div class="bg-primary/5 border-b border-outline-variant/30 p-6 flex flex-col sm:flex-row justify-between items-center gap-4">
          <div>
            <p class="text-sm text-on-surface-variant mb-1">Nomor Pesanan</p>
            <p class="font-bold text-lg">{order.order_code}</p>
          </div>
          <div class="text-right">
            <p class="text-sm text-on-surface-variant mb-1">Batas Waktu</p>
            <p class="font-bold text-red-500">{formattedExpired}</p>
          </div>
        </div>
        
        <!-- Total -->
        <div class="p-8 text-center border-b border-outline-variant/30">
          <p class="text-on-surface-variant mb-2">Total Pembayaran</p>
          <div class="flex flex-wrap items-center justify-center gap-3 mb-2">
            <h2 class="text-4xl md:text-5xl font-headline font-black text-slate-900 dark:text-white leading-none whitespace-nowrap" id="totalAmount">Rp {order.total_amount.toLocaleString('id-ID')}</h2>
            <button onclick={`navigator.clipboard.writeText('${order.total_amount}')`} class="p-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm shrink-0 flex items-center justify-center" title="Salin Nominal">
              <span class="material-symbols-outlined text-xl text-slate-600 dark:text-slate-300">content_copy</span>
            </button>
          </div>
          <p class="text-sm text-green-600 bg-green-500/10 px-3 py-1 rounded-full inline-block mt-2">Termasuk kode unik Rp {uniqueAmount}</p>
          {discountAmount > 0 && <div class="mt-4 mx-auto max-w-sm bg-green-50 border border-green-200 text-green-700 rounded-xl p-3 text-sm"><div class="flex justify-between"><span>Harga produk</span><b>Rp {subtotalAmount.toLocaleString('id-ID')}</b></div><div class="flex justify-between mt-1"><span>Diskon referral {order.referral_code && `(${order.referral_code})`}</span><b>-Rp {discountAmount.toLocaleString('id-ID')}</b></div></div>}
          <p class="text-sm mt-4 text-on-surface-variant max-w-sm mx-auto">Pastikan Anda mentransfer tepat sesuai nominal di atas hingga 3 digit terakhir untuk mempercepat verifikasi otomatis.</p>
        </div>
        
        <!-- Bank Detail -->
        <div class="p-6 md:p-8">
          <h3 class="font-bold mb-4">Transfer ke salah satu metode berikut:</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {paymentMethods.map(method => (
              <div class="bg-surface border border-outline-variant/50 rounded-xl p-4 flex flex-col h-full hover:border-primary/30 transition-colors shadow-sm">
                <div class="mb-3">
                  <p class="font-bold text-lg">{method.name}</p>
                  <p class="text-sm text-on-surface-variant line-clamp-1" title={`a.n ${method.holder}`}>a.n {method.holder}</p>
                </div>
                <div class="mt-auto">
                  <p class="font-mono text-lg font-medium tracking-widest mb-3">{method.account_number}</p>
                  <button onclick={`navigator.clipboard.writeText('${method.account_number}')`} class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-surface-container-lowest border border-outline-variant/60 rounded-lg hover:bg-surface-container-high font-bold text-sm transition-colors text-on-surface">
                    <span class="material-symbols-outlined text-base">content_copy</span>
                    Salin
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <button id="openModalBtn" class="flex-1 bg-primary text-on-primary font-bold py-4 rounded-xl hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
          Konfirmasi Pembayaran
        </button>
        <a href={`/produk-digital/pesanan/${order.order_code}`} class="flex-1 text-center bg-surface-container-high text-on-surface font-bold py-4 rounded-xl hover:bg-surface-container-highest transition-colors border border-outline-variant/50">
          Cek Status Pesanan
        </a>
      </div>
      
      <!-- Konfirmasi Modal (Hidden) -->
      <div id="confirmModal" class="fixed inset-0 z-50 bg-black/60 hidden items-center justify-center p-4">
        <div class="bg-surface rounded-2xl w-full max-w-md p-6 shadow-2xl">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold font-headline">Konfirmasi Pembayaran</h3>
            <button id="closeModalBtn" class="text-slate-400 hover:text-slate-600"><span class="material-symbols-outlined">close</span></button>
          </div>
          
          <p class="mb-4 text-on-surface-variant text-sm">Pastikan Anda sudah mentransfer <b>Rp {order.total_amount.toLocaleString('id-ID')}</b>. Isi form berikut untuk pencocokan otomatis.</p>
          
          <div class="mb-4">
            <label for="senderName" class="block text-sm font-medium mb-1">Nama Pengirim di Rekening *</label>
            <input type="text" id="senderName" class="w-full bg-surface border border-outline-variant/50 rounded-xl px-4 py-2 focus:outline-none focus:border-primary-fixed focus:ring-1 focus:ring-primary-fixed" placeholder="Misal: Budi Santoso" />
          </div>

          <div class="mb-6">
            <label for="senderBank" class="block text-sm font-medium mb-1">Bank Pengirim *</label>
            <input type="text" id="senderBank" class="w-full bg-surface border border-outline-variant/50 rounded-xl px-4 py-2 focus:outline-none focus:border-primary-fixed focus:ring-1 focus:ring-primary-fixed" placeholder="Misal: BCA / Mandiri / DANA" />
          </div>
          
          <label class="flex items-start gap-3 cursor-pointer mb-6 p-4 bg-surface-container-low border border-outline-variant/50 rounded-xl">
            <input type="checkbox" id="transferCheck" class="mt-1 w-5 h-5 rounded border-outline-variant/50 text-primary-fixed focus:ring-primary-fixed" />
            <span class="text-sm font-medium">Saya sudah melakukan transfer.</span>
          </label>
          
          <div class="flex flex-col sm:flex-row gap-3">
            <button id="proceedConfirmBtn" disabled class="flex-[2] bg-[#25D366] text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed hover:bg-[#1ebd5c] transition-colors text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Kirim via WhatsApp
            </button>
            <button id="copyConfirmBtn" disabled class="flex-1 bg-surface-container-highest text-on-surface font-bold py-3 px-4 rounded-xl flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed hover:bg-slate-200 transition-colors text-sm" title="Salin Teks Pesan">
              <span class="material-symbols-outlined text-lg">content_copy</span>
              Salin Pesan
            </button>
          </div>
        </div>
      </div>
      
    ) : (
      <div class="bg-surface-container border border-outline-variant/30 rounded-2xl p-8 text-center shadow-sm">
        <span class="material-symbols-outlined text-5xl text-yellow-500 mb-4">info</span>
        <h2 class="text-xl font-bold mb-2">Pesanan Tidak Menunggu Pembayaran</h2>
        <p class="text-on-surface-variant mb-6">Status pesanan ini saat ini adalah: <b>{order.status}</b></p>
        <a href={`/produk-digital/pesanan/${order.order_code}`} class="inline-block bg-primary text-on-primary font-bold py-3 px-6 rounded-xl hover:bg-primary/90 transition-colors">
          Lihat Status Pesanan
        </a>
      </div>
    )}

  </div>
</section>

<script is:inline define:vars={{ order, product }}>
  const modal = document.getElementById('confirmModal');
  const openBtn = document.getElementById('openModalBtn');
  const closeBtn = document.getElementById('closeModalBtn');
  const check = document.getElementById('transferCheck');
  const proceedBtn = document.getElementById('proceedConfirmBtn');

  if (openBtn) {
    openBtn.addEventListener('click', () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    });
  }

  const senderNameInput = document.getElementById('senderName');
  const senderBankInput = document.getElementById('senderBank');

  const copyConfirmBtn = document.getElementById('copyConfirmBtn');

  if (check && proceedBtn) {
    check.addEventListener('change', (e) => {
      proceedBtn.disabled = !e.target.checked;
      if (copyConfirmBtn) copyConfirmBtn.disabled = !e.target.checked;
    });

    const getMessage = () => {
      const sName = senderNameInput?.value?.trim() || '';
      const sBank = senderBankInput?.value?.trim() || '';
      if(!sName || !sBank) {
         alert("Mohon lengkapi Nama Pengirim dan Bank Pengirim terlebih dahulu.");
         return null;
      }
      return `Halo Admin VeinTech,\n\nSaya sudah melakukan pembayaran produk digital.\n\n*Detail Pesanan*\nNomor Pesanan: ${order.order_code}\nNama Pembeli: ${order.customer_name}\nProduk: ${product?.name || '-'}\n\n*Data Transfer*\nNama Pengirim: ${sName}\nBank Pengirim: ${sBank}\nTotal Transfer: Rp ${order.total_amount.toLocaleString('id-ID')}\n\nSaya akan mengirimkan foto/screenshot bukti transfer setelah pesan ini.\nMohon dilakukan verifikasi.\n\nTerima kasih.`;
    };

    const confirmOrder = async (sName, sBank) => {
      try {
        await fetch(`/api/orders/${order.id}/confirm`, { 
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ senderName: sName, senderBank: sBank })
        });
      } catch (err) {
        console.error('Failed to update status', err);
      }
    };

    proceedBtn.addEventListener('click', async () => {
      const msg = getMessage();
      if (!msg) return;
      
      proceedBtn.disabled = true;
      if (copyConfirmBtn) copyConfirmBtn.disabled = true;
      proceedBtn.innerHTML = 'Memproses...';
      
      await confirmOrder(senderNameInput.value.trim(), senderBankInput.value.trim());
      window.open(`https://wa.me/6287787290712?text=${encodeURIComponent(msg)}`, '_blank');
      window.location.href = `/produk-digital/pesanan/${order.order_code}`;
    });

    if (copyConfirmBtn) {
      copyConfirmBtn.addEventListener('click', async () => {
        const msg = getMessage();
        if (!msg) return;
        
        try {
          await navigator.clipboard.writeText(msg);
          const originalHTML = copyConfirmBtn.innerHTML;
          copyConfirmBtn.innerHTML = '<span class="material-symbols-outlined text-lg">check</span> Tersalin';
          copyConfirmBtn.classList.add('bg-green-100', 'text-green-700');
          
          setTimeout(() => {
            copyConfirmBtn.innerHTML = originalHTML;
            copyConfirmBtn.classList.remove('bg-green-100', 'text-green-700');
          }, 2000);
        } catch (err) {
          alert("Gagal menyalin teks. Silakan gunakan tombol WhatsApp.");
        }
      });
    }
  }
</script>
