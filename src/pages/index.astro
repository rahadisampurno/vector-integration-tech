---
import BaseLayout from '../layouts/BaseLayout.astro';

const techStack = [
  { icon: 'memory', label: 'Pusat AI' },
  { icon: 'cloud', label: 'Cloud Native' },
  { icon: 'forum', label: 'Orkestrasi API WhatsApp' },
  { icon: 'api', label: 'Integrasi API' },
  { icon: 'settings_slow_motion', label: 'Otomatisasi' },
  { icon: 'database', label: 'Rekayasa Data' },
  { icon: 'security', label: 'Keamanan Zero Trust' },
  { icon: 'hub', label: 'Komputasi Edge' },
  { icon: 'swap_calls', label: 'Sistem Terintegrasi' },
  { icon: 'insights', label: 'Analisis Prediktif' }
];
---

<BaseLayout title="Home">

<style>
  /* ── Video Hero ── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
  }

  .dark .hero-video-bg video {
    opacity: 0.55;
  }

  /* Gradient overlays: top + bottom fade into surface, left radial glow */
  .hero-video-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, var(--color-surface) 0%, transparent 22%, transparent 70%, var(--color-surface) 100%),
      linear-gradient(to right,  var(--color-surface) 0%, color-mix(in srgb, var(--color-surface) 40%, transparent) 55%, transparent 100%);
    pointer-events: none;
  }

  .dark .hero-video-bg::after {
    background:
      linear-gradient(to bottom, var(--color-surface) 0%, transparent 22%, transparent 70%, var(--color-surface) 100%),
      linear-gradient(to right,  rgba(10,13,20,0.82) 0%, rgba(10,13,20,0.30) 55%, rgba(10,13,20,0.10) 100%);
  }

  /* Scanline subtle noise texture overlay for cinematic depth */
  .hero-video-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.04) 2px,
      rgba(0,0,0,0.04) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Floating glow orb behind hero text */
  .hero-glow-orb {
    position: absolute;
    left: 5%;
    top: 20%;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
    z-index: 1;
    animation: orb-pulse 6s ease-in-out infinite alternate;
  }

  @keyframes orb-pulse {
    from { opacity: 0.6; transform: scale(1);   }
    to   { opacity: 1.0; transform: scale(1.12); }
  }

  /* Smooth fade-in on video load */
  .hero-video-bg video {
    animation: video-fade-in 1.4s ease forwards;
  }

  @keyframes video-fade-in {
    from { opacity: 0; }
    to   { opacity: 0.45; }
  }

  .dark @keyframes video-fade-in {
    from { opacity: 0; }
    to   { opacity: 0.55; }
  }

  /* ── Text Animations ── */
  .animate-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes reveal-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
</style>

<!-- Hero Section -->
<section class="relative min-h-[100vh] pt-32 pb-16 flex items-center overflow-hidden">

  <!-- ── Video Background ── -->
  <div class="hero-video-bg">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <!-- Primary: WebM (best compression, fastest on Chrome/Firefox) -->
      <source src="https://videos.pexels.com/video-files/3129957/3129957-uhd_2560_1440_25fps.mp4" type="video/mp4" />
      <!-- Fallback: lower resolution -->
      <source src="https://videos.pexels.com/video-files/3129957/3129957-hd_1920_1080_25fps.mp4" type="video/mp4" />
    </video>
    <div class="hero-glow-orb"></div>
  </div>
<div class="relative z-10 max-w-[1440px] mx-auto px-12 flex items-center w-full">
<div class="space-y-8 max-w-2xl">
<div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container/30 border border-outline-variant/15 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase animate-reveal">
<span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
                    Sekarang Mengintegrasikan Sistem Masa Depan
                </div>
<h1 class="text-5xl md:text-6xl xl:text-7xl font-bold leading-[1.05] tracking-tighter font-headline text-slate-900 dark:text-white break-words relative z-20 animate-reveal delay-100">
                    Meningkatkan Produktivitas dan Efisiensi <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed-dim to-on-primary-container">Alur Kerja Anda.</span>
</h1>
<p id="hero-desc-carousel" class="text-on-surface-variant text-lg leading-relaxed max-w-lg mt-6 min-h-[90px] transition-opacity duration-500 animate-reveal delay-200">
                    Menyatukan berbagai perangkat lunak bisnis Anda ke dalam satu alur kerja otomatis.
                </p>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const lines = [
            "Menyatukan berbagai perangkat lunak bisnis Anda ke dalam satu alur kerja otomatis.",
            "Menghadirkan Kecerdasan Buatan (AI) ke dalam sistem Anda untuk operasional yang lebih cerdas.",
            "Melindungi seluruh data perusahaan dengan pondasi keamanan siber tingkat tinggi (Zero Trust)."
        ];
        let i = 0;
        const el = document.getElementById("hero-desc-carousel");
        if(el) {
            setInterval(() => {
                el.style.opacity = '0';
                setTimeout(() => {
                    i = (i + 1) % lines.length;
                    el.textContent = lines[i];
                    el.style.opacity = '1';
                }, 500); 
            }, 4000); 
        }
    });
</script>
<div class="flex flex-wrap gap-4 animate-reveal delay-300">
<button class="bg-gradient-to-br from-primary-fixed-dim to-on-primary-container text-on-primary-fixed px-8 py-4 rounded-lg font-bold font-headline shadow-lg shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 transition-all hover:-translate-y-1 hover:brightness-110 flex items-center justify-center gap-2 group w-full md:w-auto">
                        Konsultasi Sekarang
                        <span class="material-symbols-outlined transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
</button>
<a href="/services" class="bg-surface-container-highest border border-primary/15 text-slate-900 dark:text-white font-bold px-8 py-4 rounded-lg hover:bg-surface-container-high transition-all flex items-center justify-center">
                        Lihat Layanan
                    </a>
</div>
</div>
</div>
</section>
<!-- Marketing Banner Section -->
<section class="py-12 bg-surface-container-lowest overflow-hidden border border-outline-variant/15 relative">
