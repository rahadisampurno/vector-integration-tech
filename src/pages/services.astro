---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Layanan | Ekosistem Solusi">
    <main class="pt-32 pb-20">
        <!-- Hero Section -->
        <header class="max-w-[1440px] mx-auto px-12 mb-24 text-center">
            <div class="space-y-6 max-w-3xl mx-auto">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim-container/30 border border-outline-variant/15 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-6 animate-reveal">
                    <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
                    Ekosistem Solusi Terpadu
                </div>
                <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] tracking-tighter font-headline text-slate-900 dark:text-white animate-reveal delay-75">
                    Katalog Lengkap <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed-dim to-on-primary-container">Layanan Kami.</span>
                </h1>
                <p class="text-xl text-on-surface-variant leading-relaxed font-body animate-reveal delay-150">
                    Jelajahi berbagai solusi teknologi mulai dari AI tingkat lanjut hingga pengembangan infrastruktur digital yang dirancang untuk mempercepat pertumbuhan bisnis Anda.
                </p>
            </div>
        </header>

        <!-- Services Grid -->
        <section class="max-w-[1440px] mx-auto px-12">
            <!-- Filter Bar -->
            <div class="flex flex-wrap justify-center gap-3 mb-16 animate-reveal delay-200">
                <button data-filter="all" class="service-filter-btn px-6 py-2.5 rounded-full bg-primary-fixed-dim/10 text-primary-fixed-dim font-headline font-bold text-sm border border-primary-fixed-dim/20 transition-all active-filter">
                    Semua Layanan
                </button>
                <button data-filter="ai-automation" class="service-filter-btn px-6 py-2.5 rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 font-headline font-bold text-sm border border-outline-variant/10 hover:border-primary-fixed-dim/30 transition-all">
                    AI & Otomatisasi
                </button>
                <button data-filter="infrastructure" class="service-filter-btn px-6 py-2.5 rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 font-headline font-bold text-sm border border-outline-variant/10 hover:border-primary-fixed-dim/30 transition-all">
                    Infrastruktur Cloud
                </button>
                <button data-filter="development" class="service-filter-btn px-6 py-2.5 rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 font-headline font-bold text-sm border border-outline-variant/10 hover:border-primary-fixed-dim/30 transition-all">
                    Pengembangan Digital
                </button>
                <button data-filter="enterprise" class="service-filter-btn px-6 py-2.5 rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 font-headline font-bold text-sm border border-outline-variant/10 hover:border-primary-fixed-dim/30 transition-all">
                    Enterprise
                </button>
                <button data-filter="business" class="service-filter-btn px-6 py-2.5 rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 font-headline font-bold text-sm border border-outline-variant/10 hover:border-amber-400/30 transition-all">
                    UMKM & Startup
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
                <!-- AI Computer Vision -->
                <a href="/services/ai-computer-vision" data-category="ai-automation enterprise" class="service-card group/item flex flex-col bg-white dark:bg-white/5 border border-outline-variant/10 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary-fixed-dim/10 hover:-translate-y-2 transition-all duration-500 animate-reveal delay-100">
                    <div class="h-64 relative overflow-hidden flex items-end p-8">
                        <img src="https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-700 opacity-80 dark:opacity-60" alt="AI Computer Vision" />
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/20 to-transparent opacity-0 group-hover/item:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
                            <p class="text-sm text-white/90 leading-relaxed mb-4 transform translate-y-4 group-hover/item:translate-y-0 transition-transform duration-500 delay-75">Analisis visual cerdas menggunakan algoritma Deep Learning untuk keamanan, pemantauan aset, dan optimasi operasional bisnis secara real-time.</p>
                            <div class="flex items-center gap-2 text-primary-fixed-dim font-bold text-xs uppercase tracking-wider transform translate-y-4 group-hover/item:translate-y-0 transition-transform duration-500 delay-150">
                                Selengkapnya
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </div>
                        </div>
                        <span class="relative z-10 text-[10px] font-mono font-bold tracking-widest text-white uppercase bg-primary-fixed-dim/80 backdrop-blur-md px-3 py-1.5 rounded-xl group-hover/item:opacity-0 transition-opacity">AI & AUTOMATION</span>
                    </div>
                    <div class="p-8 flex-1 flex flex-col bg-white dark:bg-transparent">
                        <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-3 group-hover/item:text-primary-fixed-dim transition-colors">AI Computer Vision</h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed whitespace-normal leading-tight">Solusi visi komputer cerdas untuk optimasi operasional bisnis secara real-time.</p>
                    </div>
                </a>

                <!-- Chatbot AI & NLP -->
                <a href="/services/chatbot-ai" data-category="ai-automation business" class="service-card group/item flex flex-col bg-white dark:bg-white/5 border border-outline-variant/10 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary-fixed-dim/10 hover:-translate-y-2 transition-all duration-500 animate-reveal delay-150">
                    <div class="h-64 relative overflow-hidden flex items-end p-8">
                        <img src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover group-hover/item:scale-110 transition-transform duration-700 opacity-80 dark:opacity-60" alt="Chatbot AI" />
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/20 to-transparent opacity-0 group-hover/item:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
                            <p class="text-sm text-white/90 leading-relaxed mb-4 transform translate-y-4 group-hover/item:translate-y-0 transition-transform duration-500 delay-75">Asisten virtual yang mampu memahami bahasa manusia secara alami untuk menangani keluhan pelanggan, automasi sales, dan efisiensi helpdesk 24/7.</p>
                            <div class="flex items-center gap-2 text-primary-fixed-dim font-bold text-xs uppercase tracking-wider transform translate-y-4 group-hover/item:translate-y-0 transition-transform duration-500 delay-150">
                                Selengkapnya
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </div>
                        </div>
                        <span class="relative z-10 text-[10px] font-mono font-bold tracking-widest text-white uppercase bg-primary-fixed-dim/80 backdrop-blur-md px-3 py-1.5 rounded-xl group-hover/item:opacity-0 transition-opacity">AI & AUTOMATION</span>
                    </div>
                    <div class="p-8 flex-1 flex flex-col bg-white dark:bg-transparent">
                        <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-3 group-hover/item:text-primary-fixed-dim transition-colors">Chatbot AI & NLP</h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed whitespace-normal leading-tight">Asisten virtual cerdas untuk layanan pelanggan 24/7 otomatis.</p>
                    </div>
                </a>

                <!-- System Integration API -->
                <a href="/services/integrasi-api" data-category="infrastructure enterprise" class="service-card group/item flex flex-col bg-white dark:bg-white/5 border border-outline-variant/10 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary-fixed-dim/10 hover:-translate-y-2 transition-all duration-500 animate-reveal delay-200">
