---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="AI & Otomatisasi | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — AI & Otomatisasi
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Otomatiskan <br/><span class="text-primary-fixed-dim">Bisnis Anda.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Dari chatbot cerdas hingga alur kerja lintas sistem yang berjalan otomatis — kami mengubah proses manual yang lambat menjadi mesin efisiensi berbasis AI.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/5 to-transparent"></div>
                <span class="material-symbols-outlined text-primary-fixed-dim opacity-20" style="font-size: 200px; font-variation-settings: 'FILL' 1;" data-icon="auto_awesome">auto_awesome</span>
                <div class="absolute bottom-8 left-8 right-8">
                    <div class="bg-surface/80 backdrop-blur-md border border-outline-variant/15 rounded-xl p-4">
                        <p class="text-xs text-on-surface-variant font-mono">Proses otomatis berjalan...</p>
                        <div class="flex gap-2 mt-2">
                            <div class="h-1.5 rounded-full bg-primary-fixed-dim w-2/3 animate-pulse"></div>
                            <div class="h-1.5 rounded-full bg-primary-fixed-dim w-1/4 animate-pulse" style="animation-delay:0.3s"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Feature Cards -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Apa yang Kami Otomatiskan</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="account_tree" style="font-variation-settings: 'FILL' 1;">account_tree</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Otomatisasi Alur Kerja (n8n)</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Integrasikan ratusan aplikasi bisnis seperti WhatsApp, ERP, CRM, dan email menjadi satu alur kerja tanpa sentuhan tangan manusia.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="smart_toy" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Chatbot AI Perusahaan</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Asisten virtual berbasis LLM yang bisa menjawab pertanyaan pelanggan, memproses pesanan, dan mengekskalasi tiket dukungan secara otomatis 24/7.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="description" style="font-variation-settings: 'FILL' 1;">description</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Pemrosesan Dokumen Cerdas</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">OCR + AI untuk mengekstrak data dari faktur, kontrak, dan laporan PDF secara otomatis, menghilangkan entri data manual sepenuhnya.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="troubleshoot" style="font-variation-settings: 'FILL' 1;">troubleshoot</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Dukungan Keputusan Eksekutif</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Dashboard analitik prediktif yang mengolah data mentah perusahaan menjadi sinyal keputusan operasional yang akurat dan waktu nyata.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="mark_chat_unread" style="font-variation-settings: 'FILL' 1;">mark_chat_unread</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Orkestrasi WhatsApp Business</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Otomatisasi notifikasi, pengingat pembayaran, konfirmasi pesanan, dan survei kepuasan pelanggan melalui WhatsApp API resmi.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block" data-icon="monitoring" style="font-variation-settings: 'FILL' 1;">monitoring</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Pemantauan & Pelaporan Otomatis</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Laporan KPI mingguan, bulanan, dan kuartalan yang dikirim otomatis ke email atau Slack tanpa perlu membuka satu spreadsheet pun.</p>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="bg-surface-container-low border border-outline-variant/15 rounded-2xl p-12 lg:p-16">
            <div class="mb-12">
                <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Proses Implementasi Kami</h2>
                <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">01</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Pemetaan Proses</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Kami mewawancarai tim Anda dan mengidentifikasi semua proses manual yang memakan waktu paling banyak dan paling berpotensi untuk diotomatiskan.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">02</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Perancangan & Pengembangan</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Kami merancang arsitektur workflow, memilih platform terbaik (n8n, Make, kustom), dan membangun sistem otomatisasi yang teruji secara menyeluruh.</p>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 flex items-center justify-center">
                        <span class="font-headline font-bold text-primary-fixed-dim text-lg">03</span>
                    </div>
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white">Peluncuran & Pemeliharaan</h3>
                    <p class="text-sm text-on-surface-variant font-body leading-relaxed">Kami meluncurkan sistem, melatih tim Anda, dan memberikan dukungan pemeliharaan berkelanjutan agar otomatisasi bekerja optimal setiap saat.</p>
                </div>
            </div>
        </div>
    </section>

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Siap Mengurangi 90% Pekerjaan Manual?"
        description="Jadwalkan sesi konsultasi gratis dan kami akan mengidentifikasi peluang otomatisasi tersembunyi di bisnis Anda."
        ctaText="Jadwalkan Konsultasi"
        
    />

    <ServiceBottomSections currentSlug="ai-otomatisasi" />

</main>
</BaseLayout>
