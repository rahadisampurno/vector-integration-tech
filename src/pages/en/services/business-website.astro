---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../components/ServiceBottomSections.astro";
---

<BaseLayout title="UMKM & Business Website | Services">
<main class="pt-32 pb-20">

    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#f59e0b]/10 border border-[#f59e0b]/20 rounded-full text-[#f59e0b] text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-[#f59e0b] animate-pulse"></span>
            Services — Business Website
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    A Website that <br/><span class="text-[#f59e0b]">Makes Your<br/>Business Credible.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Custom design, mobile-friendly, and ready to go live in days — not months. Designed specifically for small businesses, freelancers, and local brands that want to look professional online.
                </p>
                <div class="flex gap-4 pt-4 flex-wrap">
                    <a href="/en/contact" class="bg-[#f59e0b] text-white px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Free Consultation <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
                <div class="flex items-center gap-6 pt-2">
                    <div class="flex items-center gap-2 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b]" style="font-size:18px" data-icon="rocket_launch">rocket_launch</span>
                        Go live in 3 days
                    </div>
                    <div class="flex items-center gap-2 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b]" style="font-size:18px" data-icon="palette">palette</span>
                        Custom design, not a template
                    </div>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-br from-[#f59e0b]/5 to-transparent"></div>
                <span class="material-symbols-outlined text-[#f59e0b] opacity-20" style="font-size: 180px; font-variation-settings: 'FILL' 1;" data-icon="store">store</span>
                <div class="absolute bottom-8 left-8 right-8">
                    <div class="bg-surface/80 backdrop-blur-md border border-outline-variant/15 rounded-xl p-4">
                        <div class="flex items-center gap-3 text-xs">
                            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                            <span class="text-on-surface-variant font-mono">yourbusiness.com — Live & running</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Pricing Tiers -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12 text-center">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Choose the Right Package</h2>
            <p class="text-on-surface-variant max-w-xl mx-auto">All packages include hosting & .com domain, fully custom design (not a template), and dedicated technical support.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Single Page -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-[#f59e0b]/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Single Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Landing Page</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Focused on 1 goal, maximum conversion</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">IDR 1M <span class="text-base font-normal text-on-surface-variant">starting from</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time 3 days</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Exclusive Design (Non-Template)</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Free .com Domain & Pro Hosting</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Landing Page Layout (1 Page)</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Content Architecture & Basic Copy</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Standard SEO & Analytics Setup</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>WhatsApp & Inquiry Form Integration</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Multi-Language Ready</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Renewal fee: IDR 850,000/year</li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Best for: Product/service promos, webinar pages, app launches, short portfolios, event pages, creator link-in-bio.</p>
                    <a href="/en/contact" class="block text-center border border-[#f59e0b] text-[#f59e0b] px-6 py-3 rounded-xl font-headline font-bold hover:bg-[#f59e0b] hover:text-white transition-all text-sm">Consult Now</a>
                </div>
            </div>

            <!-- Multi Page — highlighted -->
            <div class="p-8 rounded-2xl bg-gradient-to-b from-[#f59e0b]/15 to-surface-container border border-[#f59e0b]/40 flex flex-col gap-5 relative">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#f59e0b] text-white text-[10px] font-label font-bold tracking-widest uppercase px-4 py-1 rounded-full">Most Popular</div>
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Multi Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Company Profile</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Complete, professional business presence</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">IDR 2.8M <span class="text-base font-normal text-on-surface-variant">starting from</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time starting from 3 days</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Exclusive Visuals (Business Profile)</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>High-Capacity Domain & Hosting</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Up to 5 Main Pages Included</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Advanced Persuasive Copywriting</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Lead Management via WA & Email</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>GA4 Setup & On-Page SEO</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Multi-Language Text Support</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Annual Renewal: IDR 2,500,000</li>
                </ul>
                <div class="pt-2 border-t border-[#f59e0b]/20">
                    <p class="text-xs text-on-surface-variant mb-4">Best for: Businesses needing a full company profile, brands wanting to build trust, marketing teams needing service & portfolio pages.</p>
                    <a href="/en/contact" class="block text-center bg-[#f59e0b] text-white px-6 py-3 rounded-xl font-headline font-bold hover:brightness-110 transition-all text-sm shadow-lg shadow-[#f59e0b]/20">Consult Now</a>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-[#f59e0b]/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Enterprise</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Large Scale</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Full integration, complete features</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">IDR 5M <span class="text-base font-normal text-on-surface-variant">starting from</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time starting from 5 days</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Premium UX Design (Non-Template)</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Priority Server & Corporate Domain</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Scalable Page Count to Fit Business</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Premium Content: Case Studies & Deep FAQ</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Varied UI Blocks & Functional Pages</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>API, CRM, & Auto-Booking Integrations</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Structured Data for Teams & Stakeholders</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Advanced Conversion & Event Tracking</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>Full Multi-Language Localization</li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant"><span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>SLA Technical Support & Maintenance</li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Best for: Large-scale businesses with many pages, multiple stakeholders, marketing/CRM tool integrations, consistent brand standards.</p>
                    <a href="/en/contact" class="block text-center border border-[#f59e0b] text-[#f59e0b] px-6 py-3 rounded-xl font-headline font-bold hover:bg-[#f59e0b] hover:text-white transition-all text-sm">Contact Us</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Add-ons -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-10">
            <h2 class="text-2xl md:text-3xl font-headline font-bold text-slate-900 dark:text-white mb-2">Optional Add-ons</h2>
            <p class="text-on-surface-variant text-sm">Enhance your website with extra features as needed.</p>
            <div class="w-16 h-1 bg-gradient-to-r from-[#f59e0b] to-transparent mt-3"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Dashboard Add-on</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Self-manage your content & monitor campaign and lead results. GA4 & tracking integration included.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Depends on complexity</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="mail" style="font-variation-settings: 'FILL' 1;">mail</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Professional Domain Email</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Setup domain email (name@yourbusiness.com). Includes DNS setup, account creation, & login guide.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Per account per month</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="add_circle" style="font-variation-settings: 'FILL' 1;">add_circle</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Extra Custom Pages</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Add specific custom pages as needed for Single Page or Multi Page packages.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Based on complexity</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="sell" style="font-variation-settings: 'FILL' 1;">sell</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Perpetual License</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Host the website on your own server. We assist with migration & setup on your server.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Based on package & complexity</p>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="max-w-[1440px] mx-auto px-12">
        <div class="bg-gradient-to-br from-[#f59e0b]/20 to-surface-container-low border border-[#f59e0b]/25 rounded-2xl p-12 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#f59e0b]/10 border border-[#f59e0b]/20 rounded-full text-[#f59e0b] text-xs font-label tracking-widest uppercase mb-6">100% Free Consultation</div>
            <h2 class="text-3xl md:text-5xl font-headline font-bold text-slate-900 dark:text-white mb-4">Ready to Build Your Business Website?</h2>
            <p class="text-on-surface-variant mb-8 max-w-lg mx-auto">Tell us about your business needs. We'll recommend the most suitable and cost-efficient package — no pressure, no obligation.</p>
            <a href="/en/contact" class="inline-flex items-center gap-2 bg-[#f59e0b] text-white px-10 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all shadow-lg shadow-[#f59e0b]/20">
                Start Consultation <span class="material-symbols-outlined" data-icon="chat">chat</span>
            </a>
        </div>
    </section>

    <ServiceBottomSections currentSlug="business-website" />

</main>
</BaseLayout>
