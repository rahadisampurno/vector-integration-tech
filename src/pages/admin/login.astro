---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { db } from '../../db';
import { affiliates } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { createSession, getSession, verifyPassword } from '../../lib/auth';

const { cookies, request, redirect } = Astro;
let errorMessage = '';

const existingSession = await getSession(cookies);
if (existingSession) {
  return redirect(existingSession.role === 'admin' ? '/admin/produk-digital/dashboard' : '/admin/affiliate/dashboard');
}

if (request.method === 'POST') {
  try {
    const data = await request.formData();
    const username = data.get('username');
    const password = data.get('password');
    
    // MVP Hardcoded credentials
    // Note: In production, these should come from environment variables.
    const validUsername = import.meta.env.ADMIN_USER || 'admin';
    const validPassword = import.meta.env.ADMIN_PASS || 'adminveintech';
    
    if (username === validUsername && password === validPassword) {
      await createSession(cookies, 'admin');
      return redirect('/admin/produk-digital/pesanan');
    }

    const affiliate = typeof username === 'string'
      ? await db.select().from(affiliates).where(eq(affiliates.email, username.trim().toLowerCase())).get()
      : null;
    if (affiliate?.status === 'active' && typeof password === 'string' && verifyPassword(password, affiliate.password_hash)) {
      await createSession(cookies, 'affiliate', affiliate.id);
      return redirect('/admin/affiliate/dashboard');
    }
    errorMessage = 'Username/email atau password salah.';
  } catch (e) {
    errorMessage = 'Terjadi kesalahan sistem.';
  }
}
---

<BaseLayout title="Login Admin - VeinTech">
  <div class="min-h-screen bg-surface flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="flex justify-center mb-6">
        <a href="/" class="text-2xl font-bold font-headline flex items-center gap-2">
          <span class="material-symbols-outlined text-primary-fixed">admin_panel_settings</span>
          <span>Portal Penjualan</span>
        </a>
      </div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-on-surface">
        Masuk ke akun Anda
      </h2>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-surface-container py-8 px-4 shadow sm:rounded-lg sm:px-10 border border-outline-variant/30">
        
        {errorMessage && (
          <div class="bg-red-50 text-red-600 p-3 rounded-lg mb-4 text-sm font-medium border border-red-200">
            {errorMessage}
          </div>
        )}

        <form class="space-y-6" method="POST">
          <div>
            <label for="username" class="block text-sm font-medium text-on-surface">
              Username Admin / Email Affiliate
            </label>
            <div class="mt-1">
              <input id="username" name="username" type="text" required class="appearance-none block w-full px-3 py-2 border border-outline-variant rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm bg-surface">
            </div>
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-on-surface">
              Password
            </label>
            <div class="mt-1">
              <input id="password" name="password" type="password" required class="appearance-none block w-full px-3 py-2 border border-outline-variant rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm bg-surface">
            </div>
          </div>

          <div>
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-on-primary bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors">
              Masuk
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
