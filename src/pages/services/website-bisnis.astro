---
import ServiceCTA from '../../components/ServiceCTA.astro';

import WhyChooseUs from '../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../components/ServiceEcosystem.astro';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceBottomSections from '../../components/ServiceBottomSections.astro';
---

<BaseLayout title="Website UMKM & Bisnis | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Layanan — Bisnis
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Website UMKM <br/><span class="text-primary-fixed-dim">& Bisnis.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Solusi kehadiran digital profesional untuk UMKM dan Startup. Paket lengkap yang mencakup desain kustom, domain, dan hosting dalam satu harga.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="Business Website" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Paket Digital</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">business</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Company Profile</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Website elegan untuk membangun kepercayaan pelanggan dan menampilkan portofolio bisnis Anda.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">devices</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Responsive Design</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Tampilan website yang otomatis menyesuaikan diri di smartphone, tablet, maupun komputer.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">search</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">SEO Optimized</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Struktur website yang ramah mesin pencari agar bisnis Anda lebih mudah ditemukan di Google.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Tingkatkan Kredibilitas Bisnis Anda</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Di era digital, website adalah wajah dari bisnis Anda. Kami membantu UMKM dan bisnis lokal untuk tampil profesional dengan website yang cepat dan mudah dikelola.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">speed</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Loading Super Cepat</h4>
                                <p class="text-sm text-on-surface-variant">Kami menggunakan teknologi Astro untuk memastikan website Anda dimuat seketika, meningkatkan kepuasan pengunjung.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">edit_note</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Mudah Diupdate</h4>
                                <p class="text-sm text-on-surface-variant">Panel admin yang intuitif memungkinkan Anda mengubah konten website tanpa perlu keahlian coding.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">support</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Dukungan Teknis</h4>
                                <p class="text-sm text-on-surface-variant">Tim kami siap membantu jika Anda mengalami kendala teknis atau ingin menambah fitur baru.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Service Packages -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Apa yang Anda Dapatkan?</h3>
                <div class="space-y-6">
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                        <span class="text-slate-700 dark:text-slate-300">Domain .com / .id Gratis (1 Tahun)</span>
                    </div>
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                        <span class="text-slate-700 dark:text-slate-300">Cloud Hosting High Performance</span>
                    </div>
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                        <span class="text-slate-700 dark:text-slate-300">Sertifikat SSL (HTTPS) Aman</span>
                    </div>
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                        <span class="text-slate-700 dark:text-slate-300">Integrasi WhatsApp Chat</span>
                    </div>
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-white/5 border border-outline-variant/10">
                        <span class="material-symbols-outlined text-green-500">check_circle</span>
                        <span class="text-slate-700 dark:text-slate-300">Email Bisnis Kustom (nama@bisnisanda.com)</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12 text-center">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Pilih Paket yang Tepat</h2>
            <p class="text-on-surface-variant max-w-xl mx-auto">Semua paket sudah termasuk hosting & domain .com, desain custom (bukan template), dan dukungan teknis.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Single Page -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-primary-fixed-dim/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-primary-fixed-dim tracking-widest uppercase">Single Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Landing Page</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Fokus 1 tujuan, konversi maksimal</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 1jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time 3 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Desain eksklusif (Bukan Template)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Gratis Domain .com & Hosting khusus
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Layout Landing Page (1 Halaman)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Arsitektur konten & copywriting basic
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Optimasi SEO standar & set Analytics
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Terintegrasi WhatsApp & Form inquiry
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Mendukung fitur Multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Biaya perpanjangan: Rp 850.000/tahun
                    </li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Landing page promo produk/jasa, webinar, launching aplikasi, portofolio singkat, halaman event.</p>
                    <a href="/contact" class="block text-center border border-primary-fixed-dim text-primary-fixed-dim px-6 py-3 rounded-xl font-headline font-bold hover:bg-primary-fixed-dim hover:text-white transition-all text-sm">
                        Konsultasi Sekarang
                    </a>
                </div>
            </div>

            <!-- Multi Page — highlighted -->
            <div class="p-8 rounded-2xl bg-gradient-to-b from-primary-fixed-dim/15 to-surface-container border border-primary-fixed-dim/40 flex flex-col gap-5 relative">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary-fixed-dim text-on-primary-fixed text-[10px] font-label font-bold tracking-widest uppercase px-4 py-1 rounded-full">Paling Populer</div>
                <div>
                    <span class="text-xs font-label font-bold text-primary-fixed-dim tracking-widest uppercase">Multi Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Multi Page</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Company profile lengkap</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 2,8jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time mulai dari 3 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Visual eksklusif (Sesuai profil bisnis)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Domain & Hosting kapasitas besar
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Kapasitas hingga 5 halaman utama
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Copywriting tingkat lanjut (Persuasif)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Manajemen leads via WA & Email
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Setup Google Analytics & SEO On-Page
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Dukungan teks multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Perpanjangan tahunan: Rp 2.500.000
                    </li>
                </ul>
                <div class="pt-2 border-t border-primary-fixed-dim/20">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Bisnis butuh company profile lengkap, brand yang ingin meningkatkan kepercayaan pelanggan, halaman layanan & portofolio.</p>
                    <a href="/contact" class="block text-center bg-primary-fixed-dim text-on-primary-fixed px-6 py-3 rounded-xl font-headline font-bold hover:brightness-110 transition-all text-sm shadow-lg shadow-primary-fixed-dim/20">
                        Konsultasi Sekarang
                    </a>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-primary-fixed-dim/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-primary-fixed-dim tracking-widest uppercase">Enterprise</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Skala Besar</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Integrasi penuh, fitur lengkap</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 5jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time mulai dari 5 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Desain Premium UX (Bukan Template)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Server prioritas & Domain korporat
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Jumlah halaman fleksibel sesuai skala
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Konten premium: Studi kasus & FAQ mendalam
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Komponen UI variatif & halaman fungsional
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Integrasi API, CRM, & sistem booking otomatis
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Arsitektur data untuk tim & stakeholders
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Tracking konversi advanced & Advanced SEO
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Lokalisasi konten multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-primary-fixed-dim flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Dukungan teknis SLA & pemeliharaan
                    </li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Bisnis skala besar, banyak halaman, butuh integrasi tools marketing/CRM, standar brand konsisten.</p>
                    <a href="/contact" class="block text-center border border-primary-fixed-dim text-primary-fixed-dim px-6 py-3 rounded-xl font-headline font-bold hover:bg-primary-fixed-dim hover:text-white transition-all text-sm">
                        Hubungi Kami
                    </a>
                </div>
            </div>
        </div>
    </section>

    <ServiceEcosystem />

    <WhyChooseUs />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Go Digital Sekarang, Raih Lebih Banyak Pelanggan."
        description="Jangan biarkan kompetitor mendahului Anda. Bangun kehadiran digital profesional Anda hari ini."
        ctaText="Konsultasi Website Gratis"
        
    />

    <ServiceBottomSections currentSlug="website-bisnis" />

</main>
</BaseLayout>
