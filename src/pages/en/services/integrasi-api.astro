---
import ServiceCTA from '../../../components/ServiceCTA.astro';

import WhyChooseUs from '../../../components/WhyChooseUs.astro';

import ServiceEcosystem from '../../../components/ServiceEcosystem.astro';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceBottomSections from "../../components/ServiceBottomSections.astro";
---

<BaseLayout title="System Integration API | Services">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-fixed-dim/10 border border-primary-fixed-dim/20 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
            Services — Infrastructure
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    System <br/><span class="text-primary-fixed-dim">Integration API.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Connecting third-party apps, databases, and your internal systems through secure and perfectly orchestrated API pipelines.
                </p>
                <div class="flex gap-4 pt-4">
                    <a href="/en/contact" class="bg-primary-fixed-dim text-on-primary-fixed px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Free Consultation <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <a href="/en/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        All Services
                    </a>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover opacity-60" alt="API Integration" />
                <div class="absolute inset-0 bg-gradient-to-br from-primary-fixed-dim/20 to-transparent"></div>
            </div>
        </div>
    </header>

    <!-- Feature Grid -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Integration Services</h2>
            <div class="w-20 h-1 bg-gradient-to-r from-primary-fixed-dim to-transparent"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">api</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">API Development</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Build secure, well-documented, and high-performance RESTful or GraphQL APIs.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">sync</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Data Synchronization</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Ensure data across various platforms (CRM, ERP, Database) is always synced in real-time.</p>
            </div>
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 hover:bg-surface-container transition-all group">
                <span class="material-symbols-outlined text-primary-fixed-dim text-4xl mb-5 block">cloud_done</span>
                <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-white mb-3">Cloud Migration</h3>
                <p class="text-sm text-on-surface-variant font-body leading-relaxed">Move your on-premise systems to modern cloud infrastructure with minimal downtime.</p>
            </div>
        </div>
    </section>

    <!-- Detailed Content Section -->
    <section class="max-w-[1440px] mx-auto px-12 mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <!-- Left: Benefits -->
            <div class="space-y-12">
                <div>
                    <h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white mb-6">Unify Your Digital Ecosystem</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Fragmented data is a barrier to innovation. Our integration services ensure that every component in your tech stack communicates harmoniously.</p>
                    
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">database</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Guaranteed Data Integrity</h4>
                                <p class="text-sm text-on-surface-variant">Eliminate data silos and ensure the same information is available across all your company departments.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">bolt</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">Workflow Automation</h4>
                                <p class="text-sm text-on-surface-variant">Connect different applications to run automated tasks without manual intervention.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed-dim/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary-fixed-dim">lock</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white mb-1">High-Level API Security</h4>
                                <p class="text-sm text-on-surface-variant">Implementation of OAuth2, API Keys, and end-to-end encryption to protect sensitive data exchange.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Workflow -->
            <div class="bg-slate-50 dark:bg-white/5 rounded-3xl p-10 border border-outline-variant/10">
                <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mb-8 text-center">Integration Process</h3>
                <div class="space-y-8 relative">
                    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-outline-variant/20 hidden md:block"></div>
                    
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">1</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Architecture Mapping</h4>
                            <p class="text-sm text-on-surface-variant">We map all data points and systems that need to be connected.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">2</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Middleware Development</h4>
                            <p class="text-sm text-on-surface-variant">Building efficient and scalable middleware bridges or API pipelines.</p>
                        </div>
                    </div>
                    <div class="flex gap-6 relative">
                        <div class="w-12 h-12 rounded-full bg-primary-fixed-dim text-on-primary-fixed flex items-center justify-center font-bold shrink-0 z-10">3</div>
                        <div>
                            <h4 class="font-bold text-slate-900 dark:text-white mb-1">Testing & Deployment</h4>
                            <p class="text-sm text-on-surface-variant">Load and security testing before the system is fully deployed.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    

    <ServiceEcosystem title="Ecosystem & Deep Integration" description="Our solutions are perfectly designed to connect seamlessly with your existing applications and technology infrastructure." />

    <WhyChooseUs title="Why Choose VeinTech?" subtitle="Our approach isn't just about writing code. We deliver end-to-end business solutions that guarantee ROI, security, and long-term scalability." />


    <!-- Premium CTA Component -->
    <ServiceCTA 
        title="Connect Your Business to the Future."
        description="Break the boundaries between applications. Start integrating your systems for maximum efficiency."
        ctaText="Free Integration Consultation"
        ctaLink="/en/contact"
    />

    <ServiceBottomSections currentSlug="integrasi-api" />

</main>
</BaseLayout>
