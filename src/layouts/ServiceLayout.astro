---
import BaseLayout from './BaseLayout.astro';

export interface TechSpec {
  label: string;
  value: string;
}

export interface ArchitectureStep {
  step: string;
  title: string;
  desc: string;
}

interface Props {
  title: string;
  subtitle: string;
  badge?: string;
  category?: string;
  specs?: TechSpec[];
  deliverables?: string[];
  architectureFlow?: ArchitectureStep[];
  ctaTitle?: string;
  ctaDesc?: string;
}

const {
  title,
  subtitle,
  badge = "Enterprise Engineering Service",
  category = "BUILD",
  specs = [],
  deliverables = [],
  architectureFlow = [],
  ctaTitle,
  ctaDesc
} = Astro.props;

const lang = Astro.currentLocale || 'id';

const defaultCtaTitle = lang === 'id'
  ? `Siap mengimplementasikan ${title} untuk organisasi Anda?`
  : `Ready to implement ${title} for your enterprise?`;

const defaultCtaDesc = lang === 'id'
  ? "Diskusikan kebutuhan teknis, batasan sistem, dan target timeline proyek Anda bersama principal architect VEINTECH."
  : "Discuss your architectural requirements, integration scope, and delivery timeline with a VEINTECH principal architect.";
---

<BaseLayout title={title} description={subtitle}>

  <!-- Header Banner -->
  <header class="pt-36 pb-20 bg-surface border-b border-outline-variant/15 text-on-surface">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs font-mono text-slate-500 mb-6">
        <a href={lang === 'id' ? '/' : '/en'} class="hover:text-primary-fixed-dim transition-colors">{lang === 'id' ? 'Beranda' : 'Home'}</a>
        <span>/</span>
        <a href={lang === 'id' ? '/services' : '/en/services'} class="hover:text-primary-fixed-dim transition-colors">{lang === 'id' ? 'Layanan' : 'Services'}</a>
        <span>/</span>
        <span class="text-slate-400 truncate">{title}</span>
      </nav>

      <div class="max-w-4xl space-y-6">
        <div class="flex items-center gap-3">
          <span class="px-3 py-1 rounded-full text-xs font-mono font-bold uppercase tracking-wider bg-primary-fixed-dim/15 text-primary-fixed-dim border border-primary-fixed-dim/30">
            {category}
          </span>
          <span class="text-xs font-mono text-slate-500">{badge}</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-headline tracking-tighter leading-tight text-slate-900 dark:text-white">
          {title}
        </h1>

        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed font-body">
          {subtitle}
        </p>
      </div>
    </div>
  </header>

  <!-- Architecture Flow / Blueprint (if provided) -->
  {architectureFlow.length > 0 && (
    <section class="py-16 bg-surface-container-lowest border-b border-outline-variant/15">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <div class="flex items-center gap-2 text-xs font-mono font-bold uppercase tracking-[0.2em] text-primary-fixed-dim mb-8">
          <span class="material-symbols-outlined text-base">architecture</span>
          <span>{lang === 'id' ? 'ALUR ARSITEKTUR & INTEGRASI SISTEM' : 'SYSTEM ARCHITECTURE & INTEGRATION FLOW'}</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {architectureFlow.map((step) => (
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 flex flex-col justify-between">
              <div class="space-y-3">
                <span class="text-xs font-mono font-bold text-primary-fixed-dim">{step.step}</span>
                <h3 class="font-headline font-bold text-base text-slate-900 dark:text-white">{step.title}</h3>
                <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Main Content Slot -->
  <section class="py-20 bg-surface">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <slot />
    </div>
  </section>

  <!-- Technical Specs & Engineering Deliverables -->
  {(specs.length > 0 || deliverables.length > 0) && (
    <section class="py-20 bg-surface-container-lowest border-t border-b border-outline-variant/15">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Technical Specifications Table -->
        {specs.length > 0 && (
          <div class="lg:col-span-6 space-y-6">
            <h3 class="text-xl font-bold font-headline text-slate-900 dark:text-white flex items-center gap-2">
              <span class="material-symbols-outlined text-primary-fixed-dim">terminal</span>
              <span>{lang === 'id' ? 'Spesifikasi Teknis & Standar' : 'Technical Specifications & Standards'}</span>
            </h3>
            <div class="rounded-xl border border-outline-variant/20 overflow-hidden bg-surface">
              <table class="w-full text-left text-sm">
                <tbody class="divide-y divide-outline-variant/15">
                  {specs.map((item) => (
                    <tr>
                      <th class="py-4 px-5 font-mono text-xs font-semibold text-slate-500 uppercase w-2/5 bg-surface-container-low/50">
                        {item.label}
                      </th>
                      <td class="py-4 px-5 font-medium text-slate-800 dark:text-slate-200">
                        {item.value}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <!-- Deliverables Checklist -->
        {deliverables.length > 0 && (
          <div class="lg:col-span-6 space-y-6">
            <h3 class="text-xl font-bold font-headline text-slate-900 dark:text-white flex items-center gap-2">
              <span class="material-symbols-outlined text-emerald-500">task_alt</span>
              <span>{lang === 'id' ? 'Output & Artefak yang Diserahkan' : 'Engineering Deliverables & Artifacts'}</span>
            </h3>
            <ul class="space-y-4">
              {deliverables.map((del) => (
                <li class="flex items-start gap-3 p-4 rounded-xl bg-surface border border-outline-variant/15">
                  <span class="material-symbols-outlined text-emerald-500 text-base mt-0.5">check_circle</span>
                  <span class="text-sm font-medium text-slate-800 dark:text-slate-200">{del}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Service CTA -->
  <section class="py-24 bg-surface">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 text-center max-w-3xl space-y-6">
      <h2 class="text-3xl sm:text-4xl font-bold font-headline tracking-tighter text-slate-900 dark:text-white">
        {ctaTitle || defaultCtaTitle}
      </h2>
      <p class="text-base text-slate-600 dark:text-slate-400 leading-relaxed">
        {ctaDesc || defaultCtaDesc}
      </p>
      <div class="pt-4">
        <a href={lang === 'id' ? '/contact' : '/en/contact'} class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-primary-fixed-dim hover:brightness-110 text-on-primary-fixed font-headline font-bold text-base shadow-lg shadow-primary-fixed-dim/20 transition-all">
          <span>{lang === 'id' ? 'Mulai Diskusi Proyek' : 'Initiate Project Consultation'}</span>
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
