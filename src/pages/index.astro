        <div class="flex-1 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-primary-fixed-dim/10 flex items-center justify-center mb-6 border border-primary-fixed-dim/20 text-primary-fixed-dim">
                <span class="material-symbols-outlined text-3xl" data-icon="query_stats">query_stats</span>
