---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Website UMKM & Bisnis | Layanan">
<main class="pt-32 pb-20">

    <!-- Hero Section -->
    <header class="max-w-[1440px] mx-auto px-12 mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#f59e0b]/10 border border-[#f59e0b]/20 rounded-full text-[#f59e0b] text-xs font-label tracking-widest uppercase mb-8">
            <span class="w-2 h-2 rounded-full bg-[#f59e0b] animate-pulse"></span>
            Layanan — Website UMKM & Bisnis
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-bold leading-[0.9] tracking-tighter font-headline text-slate-900 dark:text-white">
                    Website yang <br/><span class="text-[#f59e0b]">Bikin Bisnis<br/>Terlihat Kredibel.</span>
                </h1>
                <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-body">
                    Desain custom sesuai brand, mobile-friendly, dan siap go live dalam hitungan hari — bukan bulan. Khusus dirancang untuk UMKM, freelancer, dan bisnis lokal yang ingin tampil profesional di dunia digital.
                </p>
                <div class="flex gap-4 pt-4 flex-wrap">
                    <a href="/contact" class="bg-[#f59e0b] text-white px-8 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all flex items-center gap-2">
                        Konsultasi Gratis <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                    </a>
                    <a href="/services" class="border border-outline-variant/30 text-slate-600 dark:text-slate-300 px-8 py-4 rounded-xl font-headline font-bold hover:bg-surface-container-high transition-all">
                        Semua Layanan
                    </a>
                </div>
                <div class="flex items-center gap-6 pt-2">
                    <div class="flex items-center gap-2 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b]" style="font-size:18px" data-icon="rocket_launch">rocket_launch</span>
                        Go live dalam 3 hari
                    </div>
                    <div class="flex items-center gap-2 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b]" style="font-size:18px" data-icon="palette">palette</span>
                        Desain custom, bukan template
                    </div>
                </div>
            </div>
            <div class="relative h-[380px] rounded-2xl overflow-hidden border border-outline-variant/15 bg-surface-container-low flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-br from-[#f59e0b]/5 to-transparent"></div>
                <span class="material-symbols-outlined text-[#f59e0b] opacity-20" style="font-size: 180px; font-variation-settings: 'FILL' 1;" data-icon="store">store</span>
                <div class="absolute bottom-8 left-8 right-8">
                    <div class="bg-surface/80 backdrop-blur-md border border-outline-variant/15 rounded-xl p-4">
                        <div class="flex items-center gap-3 text-xs">
                            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                            <span class="text-on-surface-variant font-mono">yourumkm.com — Live & running</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Pricing Tiers -->
    <section class="max-w-[1440px] mx-auto px-12 mb-32">
        <div class="mb-12 text-center">
            <h2 class="text-3xl md:text-4xl font-headline font-bold text-slate-900 dark:text-white mb-3">Pilih Paket yang Tepat</h2>
            <p class="text-on-surface-variant max-w-xl mx-auto">Semua paket sudah termasuk hosting & domain .com, desain custom (bukan template), dan dukungan teknis.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Single Page -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-[#f59e0b]/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Single Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Landing Page</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Fokus 1 tujuan, konversi maksimal</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 1jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time 3 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Desain eksklusif (Bukan Template)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16_px" data-icon="check_circle">check_circle</span>
                        Gratis Domain .com & Hosting khusus
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Layout Landing Page (1 Halaman)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Arsitektur konten & copywriting basic
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Optimasi SEO standar & set Analytics
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Terintegrasi WhatsApp & Form inquiry
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Mendukung fitur Multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Biaya perpanjangan: Rp 850.000/tahun
                    </li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Landing page promo produk/jasa, webinar, launching aplikasi, portofolio singkat, halaman event.</p>
                    <a href="/contact" class="block text-center border border-[#f59e0b] text-[#f59e0b] px-6 py-3 rounded-xl font-headline font-bold hover:bg-[#f59e0b] hover:text-white transition-all text-sm">
                        Konsultasi Sekarang
                    </a>
                </div>
            </div>

            <!-- Multi Page — highlighted -->
            <div class="p-8 rounded-2xl bg-gradient-to-b from-[#f59e0b]/15 to-surface-container border border-[#f59e0b]/40 flex flex-col gap-5 relative">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#f59e0b] text-white text-[10px] font-label font-bold tracking-widest uppercase px-4 py-1 rounded-full">Paling Populer</div>
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Multi Page</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Multi Page</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Company profile lengkap</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 2,8jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time mulai dari 3 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Visual eksklusif (Sesuai profil bisnis)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Domain & Hosting kapasitas besar
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Kapasitas hingga 5 halaman utama
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Copywriting tingkat lanjut (Persuasif)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Manajemen leads via WA & Email
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Setup Google Analytics & SEO On-Page
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Dukungan teks multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Perpanjangan tahunan: Rp 2.500.000
                    </li>
                </ul>
                <div class="pt-2 border-t border-[#f59e0b]/20">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Bisnis butuh company profile lengkap, brand yang ingin meningkatkan kepercayaan pelanggan, halaman layanan & portofolio.</p>
                    <a href="/contact" class="block text-center bg-[#f59e0b] text-white px-6 py-3 rounded-xl font-headline font-bold hover:brightness-110 transition-all text-sm shadow-lg shadow-[#f59e0b]/20">
                        Konsultasi Sekarang
                    </a>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="p-8 rounded-2xl bg-surface-container-low border border-outline-variant/15 flex flex-col gap-5 hover:border-[#f59e0b]/30 transition-all">
                <div>
                    <span class="text-xs font-label font-bold text-[#f59e0b] tracking-widest uppercase">Enterprise</span>
                    <h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white mt-1">Skala Besar</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Integrasi penuh, fitur lengkap</p>
                </div>
                <div>
                    <p class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Rp 5jt <span class="text-base font-normal text-on-surface-variant">mulai dari</span></p>
                    <p class="text-xs text-on-surface-variant mt-1">Development time mulai dari 5 hari</p>
                </div>
                <ul class="space-y-3 flex-1">
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Desain Premium UX (Bukan Template)
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Server prioritas & Domain korporat
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Jumlah halaman fleksibel sesuai skala
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Konten premium: Studi kasus & FAQ mendalam
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Komponen UI variatif & halaman fungsional
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Integrasi API, CRM, & sistem booking otomatis
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Arsitektur data untuk tim & stakeholders
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Tracking konversi advanced & Advanced SEO
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Lokalisasi konten multi-bahasa
                    </li>
                    <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#f59e0b] flex-shrink-0" style="font-size:16px" data-icon="check_circle">check_circle</span>
                        Dukungan teknis SLA & pemeliharaan
                    </li>
                </ul>
                <div class="pt-2 border-t border-outline-variant/10">
                    <p class="text-xs text-on-surface-variant mb-4">Cocok untuk: Bisnis skala besar, banyak halaman, butuh integrasi tools marketing/CRM, standar brand konsisten.</p>
                    <a href="/contact" class="block text-center border border-[#f59e0b] text-[#f59e0b] px-6 py-3 rounded-xl font-headline font-bold hover:bg-[#f59e0b] hover:text-white transition-all text-sm">
                        Hubungi Kami
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Add-ons -->
    <section class="max-w-[1440px] mx-auto px-12 mb-32">
        <div class="mb-10">
            <h2 class="text-2xl md:text-3xl font-headline font-bold text-slate-900 dark:text-white mb-2">Opsional Tambahan</h2>
            <p class="text-on-surface-variant text-sm">Tingkatkan website Anda dengan fitur ekstra sesuai kebutuhan.</p>
            <div class="w-16 h-1 bg-gradient-to-r from-[#f59e0b] to-transparent mt-3"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Add-on Dashboard</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Update konten mandiri & pantau hasil campaign & leads. Integrasi GA4 & tracking yang diperlukan.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Tergantung kompleksitas</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="mail" style="font-variation-settings: 'FILL' 1;">mail</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Email Domain Profesional</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Setup email domain (nama@bisnisanda.com). Termasuk setup DNS, pembuatan akun, & panduan login.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Per akun per bulan</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="add_circle" style="font-variation-settings: 'FILL' 1;">add_circle</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Tambah Custom Halaman</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Tambah halaman khusus sesuai kebutuhan untuk paket Single Page atau Multi Page.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Sesuai kompleksitas</p>
            </div>
            <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant/15 hover:border-[#f59e0b]/30 transition-all">
                <span class="material-symbols-outlined text-[#f59e0b] text-3xl mb-3 block" data-icon="sell" style="font-variation-settings: 'FILL' 1;">sell</span>
                <h4 class="font-headline font-bold text-slate-900 dark:text-white mb-2">Lisensi Beli Putus</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">Host website di server milik sendiri. Kami bantu migrasi & setup di server Anda.</p>
                <p class="text-xs text-[#f59e0b] font-bold mt-3">Sesuai paket & kompleksitas</p>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-[1440px] mx-auto px-12 mb-32">
        <div class="bg-surface-container-low border border-outline-variant/15 rounded-2xl p-12 lg:p-16">
            <div class="mb-10">
                <h2 class="text-2xl md:text-3xl font-headline font-bold text-slate-900 dark:text-white mb-2">Pertanyaan Umum</h2>
                <div class="w-16 h-1 bg-gradient-to-r from-[#f59e0b] to-transparent mt-3"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Apakah saya bisa lihat dulu desainnya sebelum bayar?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Ya! Kami menyediakan sesi konsultasi gratis. Setelah memahami bisnis Anda, kami akan memberikan gambaran desain sebelum proses pembayaran dilakukan.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Apakah desainnya bisa mirip brand saya?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Tentu! Semua paket menggunakan desain custom 100% berdasarkan brand Anda — warna, font, gaya, dan tone of voice disesuaikan sepenuhnya.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Berapa lama waktu pengerjaannya?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Paket Single Page & Multi Page bisa selesai dalam 3 hari kerja setelah semua materi konten dikirimkan. Paket Enterprise mulai dari 5 hari kerja.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Hosting dan domain sudah termasuk?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Ya, semua paket sudah termasuk hosting yang andal dan domain .com selama masa langganan berlaku. Tidak ada biaya tersembunyi.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Apakah website bisa diupdate sendiri?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Dengan add-on Dashboard, Anda bisa mengupdate konten secara mandiri tanpa perlu keahlian teknis. Atau hubungi kami kapan saja untuk perubahan konten.</p>
                </div>
                <div class="space-y-2">
                    <h4 class="font-headline font-bold text-slate-900 dark:text-white">Bisa tidak pakai server sendiri?</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">Bisa! Dengan opsi Lisensi Beli Putus, website bisa dihosting di server Anda sendiri. Kami bantu proses migrasi dan setup-nya.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="max-w-[1440px] mx-auto px-12">
        <div class="bg-gradient-to-br from-[#f59e0b]/20 to-surface-container-low border border-[#f59e0b]/25 rounded-2xl p-12 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-[#f59e0b]/10 border border-[#f59e0b]/20 rounded-full text-[#f59e0b] text-xs font-label tracking-widest uppercase mb-6">
                Konsultasi 100% Gratis
            </div>
            <h2 class="text-3xl md:text-5xl font-headline font-bold text-slate-900 dark:text-white mb-4">Siap Buat Website Bisnis Anda?</h2>
            <p class="text-on-surface-variant mb-8 max-w-lg mx-auto">Ceritakan kebutuhan bisnis Anda. Kami bantu rekomendasikan paket yang paling tepat dan efisien untuk anggaran Anda — tanpa paksaan.</p>
            <a href="/contact" class="inline-flex items-center gap-2 bg-[#f59e0b] text-white px-10 py-4 rounded-xl font-headline font-bold hover:brightness-110 transition-all shadow-lg shadow-[#f59e0b]/20">
                Mulai Konsultasi <span class="material-symbols-outlined" data-icon="chat">chat</span>
            </a>
        </div>
    </section>

</main>
</BaseLayout>
