---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  date: string;
  readTime: string;
  category: string;
  authorName?: string;
  authorRole?: string;
}

const {
  title,
  summary,
  date,
  readTime,
  category,
  authorName = "VEINTECH Principal Engineering Group",
  authorRole = "Architecture & Systems Research"
} = Astro.props;

const lang = Astro.currentLocale || 'id';
---

<BaseLayout title={`${title} | VEINTECH Knowledge Center`} description={summary}>

  <!-- Article Header -->
  <header class="pt-36 pb-16 bg-surface border-b border-outline-variant/15 text-on-surface">
    <div class="max-w-4xl mx-auto px-6 md:px-12 space-y-6">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs font-mono text-slate-500">
        <a href={lang === 'id' ? '/' : '/en'} class="hover:text-primary-fixed-dim transition-colors">{lang === 'id' ? 'Beranda' : 'Home'}</a>
        <span>/</span>
        <a href={lang === 'id' ? '/insights' : '/en/insights'} class="hover:text-primary-fixed-dim transition-colors">{lang === 'id' ? 'Wawasan Teknis' : 'Insights'}</a>
        <span>/</span>
        <span class="text-slate-400 truncate">{category}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3">
        <span class="px-3 py-1 rounded text-xs font-mono font-bold uppercase tracking-wider bg-primary-fixed-dim/15 text-primary-fixed-dim border border-primary-fixed-dim/30">
          {category}
        </span>
        <span class="text-xs font-mono text-slate-500 uppercase">{date} • {readTime}</span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-headline tracking-tighter leading-tight text-slate-900 dark:text-white">
        {title}
      </h1>

      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed font-body">
        {summary}
      </p>

      <!-- Author Card -->
      <div class="pt-4 flex items-center gap-4 border-t border-outline-variant/15">
        <div class="w-11 h-11 rounded-full bg-primary-fixed-dim/15 flex items-center justify-center text-primary-fixed-dim font-bold">
          VT
        </div>
        <div>
          <span class="block text-sm font-bold text-slate-900 dark:text-white">{authorName}</span>
          <span class="block text-xs font-mono text-slate-500">{authorRole}</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Article Body -->
  <article class="py-20 bg-surface">
    <div class="max-w-4xl mx-auto px-6 md:px-12 prose prose-slate dark:prose-invert max-w-none space-y-8 text-base leading-relaxed text-slate-700 dark:text-slate-300">
      <slot />
    </div>
  </article>

  <!-- Article Footer CTA -->
  <section class="py-20 bg-surface-container-lowest border-t border-outline-variant/15">
    <div class="max-w-4xl mx-auto px-6 md:px-12 text-center space-y-6">
      <h2 class="text-2xl sm:text-3xl font-bold font-headline text-slate-900 dark:text-white">
        {lang === 'id'
          ? 'Butuh Implementasi Arsitektur Ini di Perusahaan Anda?'
          : 'Need to Implement This Architecture in Your Enterprise?'}
      </h2>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
        {lang === 'id'
          ? 'Konsultasikan langsung dengan arsitek sistem VEINTECH untuk audit atau perancangan arsitektur khusus.'
          : 'Speak directly with VEINTECH system architects for custom architecture reviews and deployment roadmaps.'}
      </p>
      <div>
        <a href={lang === 'id' ? '/contact' : '/en/contact'} class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-primary-fixed-dim text-on-primary-fixed font-headline font-bold text-sm shadow-lg shadow-primary-fixed-dim/20 hover:brightness-110 transition-all">
          <span>{lang === 'id' ? 'Konsultasi Bersama Ahli' : 'Consult With Our Engineers'}</span>
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
