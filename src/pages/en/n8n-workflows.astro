---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="n8n Workflows | VEINTECH">
<main class="pt-32 min-h-screen">
<!-- Hero Section -->
<section class="relative px-8 pb-16 pt-4 overflow-hidden">
<div class="absolute inset-0 z-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #006178 0%, transparent 70%);"></div>
<div class="max-w-6xl mx-auto relative z-10">
<div class="flex flex-col items-start gap-4">
<div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container/30 border border-outline-variant/15 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-6">
<span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
Automation Ecosystem
</div>
<h1 class="text-5xl md:text-7xl xl:text-8xl font-bold leading-[0.9] tracking-tighter md: font-headline font-bold max-w-4xl leading-tight text-slate-900 dark:text-white">
                        Automate with Ease. <br/>
<span class="gradient-text">Share n8n Workflows.</span>
</h1>
<p class="text-on-surface-variant text-xl max-w-2xl mt-4 leading-relaxed font-body">
                        Precision-engineered automation modules for VEINTECH. Deploy, scale, and optimize your kinetic intelligence pipelines with pre-built nodes.
                    </p>
</div>
</div>
</section>
<!-- Workflow Grid Section -->
<section class="px-8 pb-32">
<div class="max-w-7xl mx-auto">
<div class="flex justify-between items-end mb-12">
<div class="space-y-1">
<h2 class="text-3xl font-headline font-bold text-slate-900 dark:text-white">Community Repositories</h2>
<p class="text-on-surface-variant font-body">Browse our verified library of enterprise-grade workflows.</p>
</div>
<div class="flex gap-4">
<div class="bg-surface-container-lowest px-4 py-2 rounded-xl flex items-center gap-2 border border-outline-variant/15">
<span class="material-symbols-outlined text-primary-fixed-dim text-sm">search</span>
<input class="bg-transparent border-none focus:ring-0 text-sm w-48 text-slate-900 dark:text-white font-body placeholder-on-surface-variant" placeholder="Filter nodes..." type="text"/>
</div>
</div>
</div>
<!-- Bento Grid Layout -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-6">
<!-- Card 1 -->
<div class="md:col-span-8 group relative bg-surface-container-low rounded-xl p-8 transition-all hover:bg-surface-container border-l-2 border-transparent hover:border-primary-fixed-dim border border-outline-variant/15">
<div class="node-indicator"></div>
<div class="flex justify-between items-start mb-6">
<div class="flex gap-4 items-center">
<div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-primary-fixed-dim" style="font-variation-settings: 'FILL' 1;">sync_alt</span>
</div>
<div>
<h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white">AI CRM Sync</h3>
<span class="text-[10px] uppercase tracking-widest text-on-surface-variant bg-surface-container-highest px-2 py-0.5 rounded font-label">High Throughput</span>
</div>
</div>
<span class="text-on-surface-variant text-sm font-label">v2.4.0</span>
</div>
<p class="text-on-surface-variant mb-8 text-lg leading-relaxed font-body">
                            Synchronize leads across Salesforce, HubSpot, and internal vector databases using GPT-4 for semantic mapping and field normalization. Reduces data drift by 94%.
                        </p>
<div class="flex flex-wrap gap-4">
<button class="bg-gradient-to-br from-primary-fixed-dim to-on-primary-container text-on-primary-fixed px-8 py-4 rounded-lg font-bold font-headline shadow-lg shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 transition-all hover:-translate-y-1 hover:brightness-110 flex items-center justify-center gap-2 group w-full md:w-auto">
<span class="material-symbols-outlined text-sm">download</span>
                                Download JSON
                            </button>
<button class="bg-surface-container-highest/50 border border-outline-variant/20 px-6 py-2 rounded font-medium text-sm flex items-center gap-2 hover:bg-surface-container-high transition-colors text-slate-900 dark:text-white font-headline">
<span class="material-symbols-outlined text-sm">content_copy</span>
                                Copy URL
                            </button>
</div>
</div>
<!-- Featured Small Card 1 -->
<div class="md:col-span-4 bg-surface-container-lowest rounded-xl p-6 relative overflow-hidden group border border-outline-variant/15">
<div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
<span class="material-symbols-outlined text-8xl text-slate-900 dark:text-white" style="font-variation-settings: 'FILL' 1;">mail</span>
</div>
<div class="relative z-10 flex flex-col h-full">
<h3 class="text-xl font-headline font-bold mb-2 text-slate-900 dark:text-white">Smart Email Triage</h3>
<p class="text-on-surface-variant text-sm mb-6 flex-grow font-body">
                                Classify incoming support tickets using sentiment analysis and route to appropriate Slack channels.
                            </p>
<div class="flex flex-col gap-2">
<button class="w-full bg-surface-container-high text-primary-fixed-dim border border-primary-fixed-dim/10 py-2 rounded text-xs font-bold hover:bg-primary-container/10 transition-colors font-headline">
                                    Download JSON
                                </button>
<button class="w-full text-on-surface-variant hover:text-on-surface text-xs py-2 transition-colors font-headline">
                                    Copy Webhook URL
                                </button>
</div>
</div>
</div>
<!-- Featured Small Card 2 -->
<div class="md:col-span-4 bg-surface-container-lowest rounded-xl p-6 group border border-outline-variant/15">
<h3 class="text-xl font-headline font-bold mb-2 text-slate-900 dark:text-white">Ghost CMS Auto-Post</h3>
<p class="text-on-surface-variant text-sm mb-6 font-body">
                            Convert raw Notion documents into SEO-optimized Ghost blog posts with automated image generation.
                        </p>
<div class="flex flex-col gap-2">
<button class="w-full bg-surface-container-high text-primary-fixed-dim border border-primary-fixed-dim/10 py-2 rounded text-xs font-bold hover:bg-primary-container/10 transition-colors font-headline">
                                Download JSON
                            </button>
<button class="w-full text-on-surface-variant hover:text-on-surface text-xs py-2 transition-colors font-headline">
                                Copy Webhook URL
                            </button>
</div>
</div>
<!-- Card 4 -->
<div class="md:col-span-8 bg-surface-container-low rounded-xl p-8 relative overflow-hidden border border-outline-variant/15">
<div class="flex justify-between items-start mb-6">
<div class="flex gap-4 items-center">
<div class="w-12 h-12 bg-tertiary-container/20 rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-tertiary-fixed-dim" style="font-variation-settings: 'FILL' 1;">monitoring</span>
</div>
<div>
<h3 class="text-2xl font-headline font-bold text-slate-900 dark:text-white">Cloud Cost Monitor</h3>
<span class="text-[10px] uppercase tracking-widest text-on-surface-variant bg-surface-container-highest px-2 py-0.5 rounded font-label">Security Optimized</span>
</div>
</div>
</div>
<p class="text-on-surface-variant mb-8 text-lg leading-relaxed font-body">
                            A complex workflow monitoring AWS and Azure spend in real-time, triggering automated shutdown of non-essential dev environments when budget thresholds are breached.
                        </p>
<div class="flex flex-wrap gap-4">
<button class="bg-gradient-to-br from-primary-fixed-dim to-on-primary-container text-on-primary-fixed px-8 py-4 rounded-lg font-bold font-headline shadow-lg shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 transition-all hover:-translate-y-1 hover:brightness-110 flex items-center justify-center gap-2 group w-full md:w-auto">
<span class="material-symbols-outlined text-sm">download</span>
                                Download JSON
                            </button>
<button class="bg-surface-container-highest/50 border border-outline-variant/20 px-6 py-2 rounded font-medium text-sm flex items-center gap-2 hover:bg-surface-container-high transition-colors text-slate-900 dark:text-white font-headline">
<span class="material-symbols-outlined text-sm">content_copy</span>
                                Copy URL
                            </button>
</div>
</div>
</div>
</div>
</section>
<!-- CTA Section -->
<section class="px-8 pb-32">
<div class="max-w-5xl mx-auto">
<div class="relative glass-panel rounded-lg p-12 overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12 border border-outline-variant/10">
<div class="absolute inset-0 pointer-events-none overflow-hidden">
<img alt="" class="w-full h-full object-cover opacity-10" data-alt="abstract 3d visualization of interconnected nodes and glowing digital circuits on a dark background representing high tech connectivity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDn7sol6lNCtN3B1GwApjda85zjBKtksCnFbRlnXHMABgzqeWoC8aI37xTs53o8vbq7Dw-ZuU3ohp22YItYtVfYGsscFTRBskeP8LIeKB5W3ukA6ImHsFB7pYRypnK0pWKfvirQhIfEtbgI6zuQIjHCZJMhH4XqLEsI31fiLb10_AzrAhc3A6DnvphTRG4qxrJFgrbCavlOxiu02T3ylA8xiKMRx_GDLKVbP57jGrp9ZxmrgtN8rO1EJh_ZNKVILJIk_f8joEwak_RI"/>
</div>
<div class="relative z-10 space-y-6 max-w-xl">
<h2 class="text-4xl font-headline font-bold leading-tight text-slate-900 dark:text-white">Built a custom module? <br/><span class="text-primary-fixed-dim">Join the ecosystem.</span></h2>
<p class="text-on-surface-variant font-body">Contribute your n8n workflows to the Vector repository and help scale kinetic intelligence across the globe. Each submission is peer-reviewed for security and efficiency.</p>
</div>
<div class="relative z-10">
<button class="bg-primary/90 text-on-primary-fixed font-bold py-4 px-10 rounded-lg shadow-xl shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 hover:scale-105 transition-transform flex items-center gap-3 font-headline">
                            Submit Your Workflow
                            <span class="material-symbols-outlined">rocket_launch</span>
</button>
</div>
</div>
</div>
</section>
</main>
<style>
.node-indicator {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 4px;
    background-color: #4cd6ff;
}
.glass-panel {
    background: rgba(28, 32, 38, 0.6);
    backdrop-filter: blur(12px);
}
.gradient-text {
    background: linear-gradient(135deg, #4cd6ff 0%, #006178 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
</style>
</BaseLayout>
