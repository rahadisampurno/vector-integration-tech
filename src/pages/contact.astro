---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hubungi Kami">
<!-- Hero Section Asymmetry -->
<section class="max-w-[1440px] mx-auto px-12 mb-24 pt-32">
<div class="grid grid-cols-12 gap-8 items-end">
<div class="col-span-12 lg:col-span-7">
<div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container/30 border border-outline-variant/15 rounded-full text-primary-fixed-dim text-xs font-label tracking-widest uppercase mb-6">
<span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
Hubungi Kami
</div>
<h1 class="text-5xl md:text-7xl xl:text-8xl font-bold leading-[0.9] tracking-tighter md: font-headline font-bold text-slate-900 dark:text-white">
                        Sambungkan Ekosistem Operasional Dengan<br/>
<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed-dim to-secondary">Sistem Masa Depan.</span>
</h1>
</div>
<div class="col-span-12 lg:col-span-5 pb-4">
<p class="text-on-surface-variant text-lg max-w-md leading-relaxed">
                        Siap mengembangkan bisnis Anda secara modern? Tim ahli arsitektur IT kami bersedia mendampingi Anda untuk merombak infrastruktur ekosistem teknologi perusahaan.
                    </p>
</div>
</div>
</section>
<!-- Main Content Grid -->
<section class="max-w-[1440px] mx-auto px-12 grid grid-cols-1 md:grid-cols-12 gap-12">
<!-- Contact Form Container -->
<div class="md:col-span-7 lg:col-span-8 bg-surface-container-low rounded-xl p-10 relative border border-outline-variant/15">
<div class="node-indicator"></div>
<h2 class="text-3xl font-headline font-bold mb-8 text-slate-900 dark:text-white">Inisiasi Konsultasi Awal</h2>
<form class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-2">
<label class="text-xs font-label uppercase tracking-widest text-slate-500">Nama</label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 focus:ring-1 focus:ring-primary-fixed-dim text-on-surface placeholder:text-slate-600 transition-all font-body" placeholder="Nama Lengkap" type="text"/>
</div>
<div class="space-y-2">
<label class="text-xs font-label uppercase tracking-widest text-slate-500">Email</label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 focus:ring-1 focus:ring-primary-fixed-dim text-on-surface placeholder:text-slate-600 transition-all font-body" placeholder="surel@perusahaan.com" type="email"/>
</div>
<div class="space-y-2">
<label class="text-xs font-label uppercase tracking-widest text-slate-500">Perusahaan</label>
<input class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 focus:ring-1 focus:ring-primary-fixed-dim text-on-surface placeholder:text-slate-600 transition-all font-body" placeholder="Nama Perusahaan" type="text"/>
</div>
<div class="space-y-2">
<label class="text-xs font-label uppercase tracking-widest text-slate-500">Kebutuhan layanan</label>
<select class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 focus:ring-1 focus:ring-primary-fixed-dim text-on-surface transition-all font-body">
<option>Integrasi Ekosistem Sistem</option>
<option>Penyebaran Infrastruktur Cloud</option>
<option>Pelatihan Kecerdasan Nalar Data</option>
<option>Pemasangan Keamanan Siber Lapis Tiga</option>
</select>
</div>
<div class="md:col-span-2 space-y-2">
<label class="text-xs font-label uppercase tracking-widest text-slate-500">Pesan dan Detail Proyek</label>
<textarea class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl p-4 focus:ring-1 focus:ring-primary-fixed-dim text-on-surface placeholder:text-slate-600 transition-all font-body" placeholder="Ceritakan sedetail mungkin dengan spesifik mengenai kendala serta target rencana perusahaan Anda..." rows="5"></textarea>
</div>
<div class="md:col-span-2 pt-4">
<button type="button" class="bg-gradient-to-br from-primary-fixed-dim to-on-primary-container text-on-primary-fixed px-8 py-4 rounded-lg font-bold font-headline shadow-lg shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20 transition-all hover:-translate-y-1 hover:brightness-110 flex items-center justify-center gap-2 group w-full md:w-auto">
                            Kirim Pertanyaan
                        </button>
</div>
</form>
</div>
<!-- Sidebar Info -->
<div class="md:col-span-5 lg:col-span-4 space-y-8">
<!-- Contact Info Cards -->
<div class="bg-surface-container-low rounded-xl p-8 relative overflow-hidden border border-outline-variant/15">
<div class="node-indicator"></div>
<div class="relative z-10">
<h3 class="text-xl font-headline font-bold mb-6 text-slate-900 dark:text-white">Kontak Komunikasi Langsung</h3>
<div class="space-y-6">
<div class="flex items-start gap-4">
<div class="bg-primary-container/10 p-3 rounded-lg">
<span class="material-symbols-outlined text-primary-fixed-dim">mail</span>
</div>
<div>
<p class="text-xs font-label uppercase tracking-widest text-slate-500 mb-1">Alamat Surel (Email)</p>
<p class="text-on-surface font-medium font-body">connect@vit-systems.com</p>
</div>
</div>
<div class="flex items-start gap-4">
<div class="bg-primary-container/10 p-3 rounded-lg">
<span class="material-symbols-outlined text-primary-fixed-dim">chat</span>
</div>
<div>
<p class="text-xs font-label uppercase tracking-widest text-slate-500 mb-1">Kontak WhatsApp Server</p>
<p class="text-on-surface font-medium font-body">+62 812-3456-7890</p>
</div>
</div>
<div class="flex items-start gap-4">
<div class="bg-primary-container/10 p-3 rounded-lg">
<span class="material-symbols-outlined text-primary-fixed-dim">location_on</span>
</div>
<div>
<p class="text-xs font-label uppercase tracking-widest text-slate-500 mb-1">Alamat Kantor Bisnis Operasional</p>
<p class="text-on-surface font-medium leading-relaxed font-body">
                                        Gedung Pusat Vector Plaza, Lantai 42<br/>
                                        Sudirman Central Business District (SCBD)<br/>
                                        Jakarta Selatan, Indonesia 12190
                                    </p>
</div>
</div>
</div>
</div>
<!-- Subtle Tech Background Ornament -->
<div class="absolute -bottom-10 -right-10 opacity-5 pointer-events-none">
<span class="material-symbols-outlined text-[160px]">hub</span>
</div>
</div>
<!-- Small Map Preview or Identity Card -->
<div class="bg-surface-container p-8 rounded-lg border border-outline-variant/10">
<p class="text-sm italic text-on-surface-variant leading-relaxed font-body">
                        "VEIN mengubah sistem yang terfragmentasi parah layaknya reruntuhan kaca menjadi sebuah tameng operasional terpadu yang kokoh. Staf dukungan spesialis teknis tim kami siap siaga untuk merespons anda sesegera mungkin di jam kerja operasional."
                    </p>
<div class="mt-4 flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-slate-800 overflow-hidden">
<img class="w-full h-full object-cover" data-alt="professional male executive portrait in dark suit with focused expression and corporate tech background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBK54rD8iVFS4PU5Xd5x9-ZvWRgQSYdNheU3Uu86y1fz9-weRHR4YBrCkui4i_tsMgMFRkxFuEe0OOy37EJOOR7XlwLwf4799K-NXuu7LmOvDDSEU1ONBeBGcrasS_aTSGy9g1jRm-DQ3EP9DRDzqQ0Hy0owKaSPKtZz0gB9WQ6NSqKK1CjbKa8wXgWABTM_z6vyw1WwjKWCadBbMyAh8-OjNYcxEACz_anCXfRQOMEcS8WYxpCEhVy7rf-TgILlnq5IGx-tQ8KIWNW"/>
</div>
<div>
<p class="text-sm font-bold text-slate-900 dark:text-white font-headline">Kepala Transformasi Eksekutif IT</p>
<p class="text-xs text-slate-500 font-body">Vector Integration Tech</p>
</div>
</div>
</div>
</div>
</section>
<!-- Map Section -->
<section class="max-w-[1440px] mx-auto px-12 mt-20 mb-20">
<div class="rounded-xl overflow-hidden h-[500px] relative border border-outline-variant/10">
<div class="absolute inset-0 bg-surface-container-lowest flex items-center justify-center border border-outline-variant/15">
<!-- High-tech map representation -->
<div class="w-full h-full opacity-50 grayscale contrast-125" data-alt="stylized dark monochrome map of a modern city center with neon data connection lines and digital overlays" data-location="Jakarta" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDqYvSgoynTvmQ1S2XrOMZp8WKqLsOtC7dj8kz-EZDzy-um1X5se50RPrF-LiaOL2wo0oVB5MfGdkizbefn1-Q1-HQ9_8N2j7OyA7AkIs_yj2BS6u84dCtb4LxhxnLqAWTwRdx_OODuhGo8vaTI932-MFlx2Er3zd87Um0l3g-bZQVbD-2LGVagdZsdnX5Y0_rOgIpouXlDUG6DnExQljFTv8_J-ZOVK7ABQCXKxsZkmTmU_KLfHQXjvLSUHMVAOGS86iClh4fj6rto'); background-size: cover; background-position: center;">
</div>
<div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent"></div>
<!-- Map Pin -->
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
<div class="bg-primary-fixed-dim text-on-primary-fixed px-4 py-2 rounded-lg font-headline font-bold mb-2 shadow-2xl shadow-primary-fixed-dim/40 dark:shadow-primary-fixed-dim/20">
                            KANTOR PUSAT VEIN JAKARTA
                        </div>
<div class="w-6 h-6 bg-primary-fixed-dim rounded-full animate-pulse flex items-center justify-center">
<div class="w-2 h-2 bg-on-primary-fixed rounded-full"></div>
</div>
</div>
</div>
<!-- Floating Map Overlay -->
<div class="absolute bottom-8 left-8 bg-surface-container-high/80 backdrop-blur-md p-6 rounded-lg max-w-xs border border-outline-variant/20">
<h4 class="text-slate-900 dark:text-white font-headline font-bold mb-2">Kunjungi Fasilitas Lab Kami</h4>
<p class="text-on-surface-variant text-sm mb-4 font-body">Saksikan dengan mata kepala Anda sendiri bagaimana tim teknisi ahli kami memantau pergerakan jutaan bit data lewat pusat komando operasi kami di Jakarta.</p>
<a class="text-primary-fixed-dim text-sm font-bold flex items-center gap-2 hover:translate-x-1 transition-transform font-headline cursor-pointer">
                        Lihat Panduan Arah Navigasi Peta Google Maps
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
</a>
</div>
</div>
</section>
</BaseLayout>
