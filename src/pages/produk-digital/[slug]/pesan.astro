---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CheckoutContent from '../../../components/produk-digital/CheckoutContent.astro';
import { db } from '../../../db';
import { products, orders, affiliates } from '../../../db/schema';
import { eq } from 'drizzle-orm';
import { randomBytes } from 'node:crypto';
import { normalizeWhatsAppNumber } from '../../../utils/validation';

const { slug } = Astro.params;
let errorMessage = '';
let formValues = {
  customer_name: '',
  business_name: '',
  referral_code: '',
  whatsapp: '',
  email: '',
  terms_accepted: false
};

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const name = data.get('customer_name')?.toString() || '';
    const whatsapp = data.get('whatsapp')?.toString() || '';
    const email = data.get('email')?.toString() || '';
    const businessName = data.get('business_name')?.toString() || '';
    const referralCode = data.get('referral_code')?.toString().trim().toUpperCase() || '';
    formValues = {
      customer_name: name,
      business_name: businessName,
      referral_code: referralCode,
      whatsapp,
      email,
      terms_accepted: data.get('terms_accepted') === 'on'
    };
    
    if (!name || !whatsapp || !email) {
      throw new Error('Nama, WhatsApp, dan Email wajib diisi.');
    }
    const affiliate = referralCode
      ? await db.select().from(affiliates).where(eq(affiliates.referral_code, referralCode)).get()
      : null;
    if (referralCode && (!affiliate || affiliate.status !== 'active')) {
      throw new Error('Kode referral tidak valid atau sudah tidak aktif.');
    }
    
    // Normalize WhatsApp (08x -> 628x)
    const normalizedWa = normalizeWhatsAppNumber(whatsapp);
    
    let product = {
      id: 'test-product',
      slug: 'veintools-desktop',
      name: 'VeinTools Desktop',
      category: 'Aplikasi Desktop',
      regular_price: 199000,
      sale_price: null as number | null,
      thumbnail_url: '/veintools_logo.png'
    };

    if (slug) {
      const dbProduct = await db.select().from(products).where(eq(products.slug, slug)).get();
      if (dbProduct?.status === 'active') {
        product = dbProduct as any;
      } else if (dbProduct) {
        throw new Error('Produk sedang tidak tersedia.');
      }
    }
    
    // Generate order code VD-YYYYMMDD-XXXXXX
    const date = new Date();
    const dateStr = date.toISOString().split('T')[0].replace(/-/g, '');
    const randomStr = randomBytes(3).toString('hex').toUpperCase();
    const orderCode = `VD-${dateStr}-${randomStr}`;
    
    // Kode unik
    const uniqueAmount = Math.floor(Math.random() * 900) + 100;
    const subtotalAmount = product.sale_price || product.regular_price;
    const discountAmount = affiliate ? Math.round(subtotalAmount * affiliate.discount_rate / 100) : 0;
    const affiliateCommission = affiliate ? Math.round((subtotalAmount - discountAmount) * affiliate.commission_rate / 100) : 0;
    const totalAmount = subtotalAmount - discountAmount + uniqueAmount;
    
    // Ensure product exists in DB to prevent foreign key constraint error
    const existingProduct = await db.select().from(products).where(eq(products.id, product.id)).get();
    if (!existingProduct) {
       await db.insert(products).values({
         id: product.id,
         slug: product.slug,
         name: product.name,
         category: product.category,
         regular_price: product.regular_price,
         thumbnail_url: product.thumbnail_url,
         created_at: new Date()
       }).run();
    }
    
    // Save order
    await db.insert(orders).values({
      id: crypto.randomUUID(),
      order_code: orderCode,
      product_id: product.id,
      customer_name: name,
      whatsapp: normalizedWa,
      email: email,
      business_name: businessName,
      referral_code: referralCode || null,
      affiliate_id: affiliate?.id || null,
      subtotal_amount: subtotalAmount,
      discount_amount: discountAmount,
      affiliate_commission: affiliateCommission,
      commission_status: 'pending',
      total_amount: totalAmount,
      status: 'WAITING_PAYMENT',
      created_at: new Date()
    }).run();
    
    return Astro.redirect(`/produk-digital/pesanan/${orderCode}/pembayaran`);
  } catch (error) {
    if (error instanceof Error) {
      errorMessage = error.message;
    }
  }
}
---

<BaseLayout title="Pesan Produk Digital - VeinTech">
  <CheckoutContent slug={slug} locale="id" errorMessage={errorMessage} formValues={formValues} />
</BaseLayout>
